@page "/resetpassword"
@using Microsoft.AspNetCore.WebUtilities
@using System.ComponentModel.DataAnnotations
@using Microsoft.EntityFrameworkCore
@using FerrexWeb.Models
@using FerrexWeb.Services
@inject NavigationManager NavigationManager
@inject ApplicationDbContext DbContext

<div class="reset-container">
    <div class="reset-card">
        <div class="reset-icon">
            <i class="fas fa-lock"></i>
        </div>
        <h3>Restablecer contraseña</h3>

        @if (processing)
        {
            <div class="reset-loading">
                <i class="fas fa-spinner fa-spin"></i>
                <p>Validando enlace...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="reset-status error">
                <div class="status-icon">
                    <i class="fas fa-times-circle"></i>
                </div>
                <p>@errorMessage</p>
                <button class="reset-button"
                        @onclick='() => NavigationManager.NavigateTo("/userinfo")'>
                    Ir al inicio de sesión
                </button>
            </div>
        }
        else if (resetCompleted)
        {
            <div class="reset-status success">
                <div class="status-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <p>Tu contraseña ha sido actualizada exitosamente.</p>
                <button class="reset-button"
                        @onclick='() => NavigationManager.NavigateTo("/userinfo")'>
                    Iniciar sesión
                </button>
            </div>
        }
        else
        {
            <p class="reset-subtitle">Ingresa tu nueva contraseña</p>
            <EditForm Model="model" OnValidSubmit="HandleResetPassword">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="reset-form">
                    <InputText type="password"
                               class="reset-input"
                               @bind-Value="model.NewPassword"
                               placeholder="Nueva contraseña" />
                    <InputText type="password"
                               class="reset-input"
                               @bind-Value="model.ConfirmPassword"
                               placeholder="Confirmar contraseña" />

                    <button type="submit" class="reset-button" disabled="@isSubmitting">
                        @(isSubmitting ? "Guardando..." : "Cambiar contraseña")
                    </button>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    private bool    processing     = true;
    private bool    isSubmitting   = false;
    private bool    resetCompleted = false;
    private string  errorMessage;
    private ResetModel model       = new();

    private class ResetModel
    {
        public string Token { get; set; }

        [Required(ErrorMessage = "La nueva contraseña es obligatoria.")]
        [MinLength(8, ErrorMessage = "Mínimo 8 caracteres.")]
        [RegularExpression(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^\w]).{8,}$",
            ErrorMessage = "Debe incluir mayúscula, número y carácter especial.")]
        [DataType(DataType.Password)]
        public string NewPassword { get; set; }

        [Required(ErrorMessage = "Confirma tu contraseña.")]
        [Compare(nameof(NewPassword), ErrorMessage = "Las contraseñas no coinciden.")]
        [DataType(DataType.Password)]
        public string ConfirmPassword { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var uri   = new Uri(NavigationManager.Uri);
        var qs    = QueryHelpers.ParseQuery(uri.Query);
        if (!qs.TryGetValue("token", out var t) || string.IsNullOrWhiteSpace(t))
        {
            errorMessage = "Token inválido.";
            processing   = false;
            return;
        }
        model.Token = t;

        var pr = await DbContext.PasswordResets
                    .AsTracking()
                    .Include(x => x.User)
                    .FirstOrDefaultAsync(x => x.Token == model.Token);

        if (pr == null)
        {
            errorMessage = "Enlace no encontrado o ya fue utilizado.";
            processing   = false;
            return;
        }

        if (pr.ExpiresAt < DateTime.UtcNow)
        {
            errorMessage = "El enlace ha expirado. Solicita uno nuevo desde el inicio de sesión.";
            processing   = false;
            return;
        }

        processing = false;
    }

    private async Task HandleResetPassword()
    {
        if (isSubmitting) return;
        isSubmitting = true;

        try
        {
            var pr = await DbContext.PasswordResets
                        .AsTracking()
                        .Include(x => x.User)
                        .FirstOrDefaultAsync(x => x.Token == model.Token);

            if (pr == null || pr.ExpiresAt < DateTime.UtcNow)
            {
                errorMessage  = "El enlace ya no es válido.";
                isSubmitting  = false;
                return;
            }

            pr.User.Password = BCrypt.Net.BCrypt.HashPassword(model.NewPassword);
            DbContext.PasswordResets.Remove(pr);
            await DbContext.SaveChangesAsync();

            resetCompleted = true;
        }
        catch
        {
            errorMessage = "Ocurrió un error al restablecer la contraseña. Inténtalo de nuevo.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}

<style>
    .reset-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 20px;
        font-family: 'Jost', sans-serif;
        box-sizing: border-box;
    }

    .reset-card {
        background: #fff;
        border-radius: 15px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.1);
        padding: 40px;
        text-align: center;
        max-width: 450px;
        width: 100%;
        box-sizing: border-box;
    }

        .reset-card h3 {
            margin: 10px 0 5px;
            font-size: 1.5em;
            color: #333;
        }

    .reset-icon {
        font-size: 2.5em;
        color: #F5C144;
        margin-bottom: 5px;
    }

    .reset-subtitle {
        color: #666;
        font-size: 0.95em;
        margin-bottom: 15px;
    }

    .reset-form {
        display: flex;
        flex-direction: column;
        gap: 12px;
        align-items: center;
    }

    .reset-input {
        width: 100%;
        max-width: 320px;
        height: 48px;
        background: #f5f5f5;
        margin: 0 auto;
        padding: 10px 15px;
        border: 1px solid #ddd;
        outline: none;
        border-radius: 8px;
        font-size: 1em;
        box-sizing: border-box;
        transition: border-color 0.3s;
    }

        .reset-input:focus {
            border-color: #F5C144;
        }

    .reset-button {
        display: inline-block;
        padding: 12px 30px;
        width: 100%;
        max-width: 320px;
        background: #F5C144;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 1em;
        font-weight: bold;
        cursor: pointer;
        transition: background 0.3s;
        margin-top: 5px;
    }

        .reset-button:hover {
            background: #000;
        }

        .reset-button:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

    .reset-loading {
        padding: 20px 0;
        color: #F5C144;
        font-size: 1.5em;
    }

        .reset-loading p {
            font-size: 0.65em;
            color: #666;
            margin-top: 10px;
        }

    .reset-status {
        padding: 15px 0;
    }

    .status-icon {
        font-size: 2.5em;
        margin-bottom: 10px;
    }

    .reset-status.success .status-icon {
        color: #28a745;
    }

    .reset-status.error .status-icon {
        color: #dc3545;
    }

    .reset-status p {
        color: #666;
        font-size: 1em;
        margin-bottom: 20px;
    }

    /* Validación de Blazor */
    .validation-summary-errors {
        color: #dc3545;
        font-size: 0.85em;
        text-align: left;
        width: 100%;
        max-width: 320px;
        margin: 0 auto 10px;
    }

        .validation-summary-errors ul {
            padding-left: 20px;
            margin: 5px 0;
        }

    .validation-message {
        color: #dc3545;
        font-size: 0.8em;
    }

    /* Tablet */
    @@media (max-width: 768px) {
        .reset-card {
            padding: 30px 25px;
        }
    }

    /* Movil */
    @@media (max-width: 480px) {
        .reset-container {
            padding: 15px 10px;
        }

        .reset-card {
            padding: 25px 15px;
            border-radius: 10px;
        }

            .reset-card h3 {
                font-size: 1.3em;
            }

        .reset-icon {
            font-size: 2em;
        }

        .reset-input {
            max-width: none;
            width: 100%;
            height: 45px;
        }

        .reset-button {
            max-width: none;
            width: 100%;
        }

        .validation-summary-errors {
            max-width: none;
        }
    }
</style>
