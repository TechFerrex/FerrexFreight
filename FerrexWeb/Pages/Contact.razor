@page "/contact"
@using System.ComponentModel.DataAnnotations
@using System.Net.Mail
@using System.Net
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

@code {
    private ContactFormModel formModel = new();
    private bool isSubmitted = false;
    private string errorMessage = null;

    private async Task HandleValidSubmit()
    {
        errorMessage = null;
        try
        {
            await SendEmail();
            isSubmitted = true;
        }
        catch (SmtpException)
        {
            errorMessage = "No se pudo enviar el mensaje en este momento. Por favor, intenta de nuevo más tarde o contáctanos directamente por WhatsApp o teléfono.";
        }
        catch (Exception)
        {
            errorMessage = "Ocurrió un error inesperado. Por favor, intenta de nuevo más tarde.";
        }
    }

    private async Task SendEmail()
    {
        var brevoConfig = Configuration.GetSection("BrevoSmtp");
        var fromEmail = brevoConfig["FromEmail"] ?? "techferrexpress@outlook.com";
        var fromName = "Ferrexpress Contact Form";
        var toEmail = "ferrexpresshn@gmail.com";
        var toName = "Ferrexpress";

        var subject = $"[Contacto] {System.Net.WebUtility.HtmlEncode(formModel.Subject)}";

        var safeName = System.Net.WebUtility.HtmlEncode(formModel.Name);
        var safeEmail = System.Net.WebUtility.HtmlEncode(formModel.Email);
        var safeMessage = System.Net.WebUtility.HtmlEncode(formModel.Message);

        var htmlContent = $"<p><strong>Nombre:</strong> {safeName}</p>" +
                          $"<p><strong>Email:</strong> {safeEmail}</p>" +
                          $"<p><strong>Mensaje:</strong></p><p>{safeMessage}</p>";

        using var mailMessage = new MailMessage()
            {
                From = new MailAddress(fromEmail, fromName),
                Subject = subject,
                Body = htmlContent,
                IsBodyHtml = true
            };
        mailMessage.ReplyTo = new MailAddress(formModel.Email, formModel.Name);
        mailMessage.To.Add(new MailAddress(toEmail, toName));

        var smtpHost = brevoConfig["Host"] ?? "smtp-relay.brevo.com";
        var smtpPort = int.TryParse(brevoConfig["Port"], out var p) ? p : 587;

        using var smtpClient = new SmtpClient(smtpHost, smtpPort)
            {
                Credentials = new NetworkCredential(brevoConfig["User"], brevoConfig["Pass"]),
                EnableSsl = true
            };
        await smtpClient.SendMailAsync(mailMessage);
    }

    public class ContactFormModel
    {
        [Required(ErrorMessage = "El nombre es requerido.")]
        public string Name { get; set; }

        [Required(ErrorMessage = "El correo electrónico es requerido.")]
        [EmailAddress(ErrorMessage = "Por favor ingresa un correo electrónico válido.")]
        public string Email { get; set; }

        [Required(ErrorMessage = "El asunto es requerido.")]
        public string Subject { get; set; }

        [Required(ErrorMessage = "El mensaje es requerido.")]
        public string Message { get; set; }
    }
}

<div class="container my-5 blury-content">
    <h1 class="display-4 text-center mb-4">Contáctanos</h1>
    <hr class="mb-5" />
    <div class="row">
        <!-- Sección de Información de Contacto -->
        <div class="col-md-6">
            <h2>Estamos aquí para ayudarte</h2>
            <p>Si tienes preguntas o necesitas más información, no dudes en contactarnos a través de los siguientes medios:</p>
            <ul class="list-unstyled contact-info">
                <li>
                    <i class="fas fa-envelope" style="color: #3b5998"></i>
                    <a href="mailto:ferrexpresshn@gmail.com">ferrexpresshn@gmail.com</a>
                </li>
                <li>
                    <i class="fas fa-phone-alt"></i>
                    <a href="tel:+50432024761">+504 3202-4761</a>
                </li>
                <li>
                    <i class="fas fa-map-marker-alt"></i>
                    San Pedro Sula, Honduras
                </li>
            </ul>
            <!-- Redes Sociales -->
            <div class="social-media mt-4">
                <a href="https://www.facebook.com/profile.php?id=615556746360913" target="_blank" style="color: #3b5998">
                    <i class="fab fa-facebook-f"></i>
                </a>
                <a href="https://www.instagram.com/ferrexpresshn" target="_blank" style="color: #bc2a8d ">
                    <i class="fab fa-instagram"></i>
                </a>
                <a href="https://wa.link/3cwl53" target="_blank" style="color: #25d366">
                    <i class="fab fa-whatsapp"></i>
                </a>
            </div>
        </div>
        <!-- Sección del Formulario de Contacto -->
        <div class="col-md-6">
            <h2>Envíanos un mensaje</h2>

            @if (isSubmitted)
            {
                <div class="alert alert-success" role="alert">
                    ¡Formulario enviado con éxito! Nos pondremos en contacto contigo pronto.
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger" role="alert">
                        @errorMessage
                    </div>
                }
                <EditForm Model="@formModel" OnValidSubmit="@HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label for="name" class="form-label">Nombre</label>
                        <InputText id="name" class="form-control" @bind-Value="formModel.Name" placeholder="Tu nombre completo" />
                        <ValidationMessage For="@(() => formModel.Name)" />
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">Correo Electrónico</label>
                        <InputText id="email" class="form-control" @bind-Value="formModel.Email" placeholder="tuemail@ejemplo.com" />
                        <ValidationMessage For="@(() => formModel.Email)" />
                    </div>

                    <div class="mb-3">
                        <label for="subject" class="form-label">Asunto</label>
                        <InputText id="subject" class="form-control" @bind-Value="formModel.Subject" placeholder="Asunto del mensaje" />
                        <ValidationMessage For="@(() => formModel.Subject)" />
                    </div>

                    <div class="mb-3">
                        <label for="message" class="form-label">Mensaje</label>
                        <InputTextArea id="message" class="form-control" @bind-Value="formModel.Message" rows="5" placeholder="Escribe tu mensaje aquí..."></InputTextArea>
                        <ValidationMessage For="@(() => formModel.Message)" />
                    </div>
                    <button type="submit" class="btn btn-primary">Enviar Mensaje</button>
                </EditForm>
            }
        </div>
    </div>
</div>

<style>
    body {
        background-image: url('images/construccion.png');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

    /* Fondo borroso para el contenido */
    .blury-content {
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(10px);
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .contact-info li {
        margin-bottom: 15px;
        font-size: 18px;
    }

        .contact-info li i {
            color: #F5C144;
            margin-right: 10px;
        }

    .social-media a {
        font-size: 24px;
        margin-right: 15px;
        transition: color 0.3s;
    }

        .social-media a:hover {
            color: #F5C144;
        }

    .btn-primary {
        background-color: #F5C144;
        border-color: #F5C144;
    }

        .btn-primary:hover {
            background-color: #A7A9AC;
            border-color: #A7A9AC;
        }

    .form-label {
        color: #000000;
    }

    .form-control:focus {
        border-color: #F5C144;
        box-shadow: none;
    }

    @@media (max-width: 768px) {
        .blury-content {
            padding: 15px;
            margin-top: 1.5rem !important;
            margin-bottom: 1.5rem !important;
        }

        .display-4 {
            font-size: 1.5rem;
        }

        .contact-info li {
            font-size: 15px;
        }

        h2 {
            font-size: 1.3rem;
            margin-bottom: 0.75rem;
        }

        .col-md-6 {
            margin-bottom: 1.5rem;
        }

        .btn-primary {
            width: 100%;
            min-height: 48px;
            font-size: 1rem;
        }

        .social-media a {
            font-size: 28px;
            margin-right: 20px;
            min-width: 44px;
            min-height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
    }

    @@media (max-width: 480px) {
        .blury-content {
            padding: 12px;
            margin-top: 1rem !important;
            margin-bottom: 1rem !important;
        }

        .display-4 {
            font-size: 1.3rem;
        }

        .contact-info li {
            font-size: 14px;
            margin-bottom: 12px;
        }

        h2 {
            font-size: 1.15rem;
        }

        .form-control {
            font-size: 16px;
        }
    }
</style>
