@page "/userinfo"
@using Microsoft.EntityFrameworkCore
@using FerrexWeb.Services
@using FerrexWeb.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using System.IdentityModel.Tokens.Jwt
@using Microsoft.IdentityModel.Tokens
@using System.Text
@inject Blazored.LocalStorage.ILocalStorageService LocalStorageService
@inject IEmailSender EmailSender
@inject IConfiguration _configuration
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@using System.ComponentModel.DataAnnotations

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <div class="brand-logo">
                <i class="fas fa-screwdriver-wrench"></i>
            </div>
            <h1 class="auth-title">Ferrexpress</h1>
            <p class="auth-subtitle">
                @(activeTab == "login" ? "Bienvenido de nuevo" : "Crea tu cuenta en segundos")
            </p>
        </div>

        <div class="auth-tabs" role="tablist">
            <button type="button"
                    class="auth-tab @(activeTab == "login" ? "active" : "")"
                    @onclick='() => SwitchTab("login")'>
                <i class="fas fa-right-to-bracket"></i>
                <span>Iniciar sesión</span>
            </button>
            <button type="button"
                    class="auth-tab @(activeTab == "register" ? "active" : "")"
                    @onclick='() => SwitchTab("register")'>
                <i class="fas fa-user-plus"></i>
                <span>Registrarse</span>
            </button>
        </div>

        <div class="auth-body">
            @if (activeTab == "login")
            {
                <form class="auth-form" @onsubmit:preventDefault="true" autocomplete="on">
                    @if (!string.IsNullOrEmpty(loginError))
                    {
                        <div class="auth-alert auth-alert-error">
                            <i class="fas fa-circle-exclamation"></i>
                            <span>@loginError</span>
                        </div>
                    }

                    <div class="field">
                        <label class="field-label">Correo electrónico</label>
                        <div class="input-wrap">
                            <i class="fas fa-envelope input-icon"></i>
                            <input type="email"
                                   class="field-input"
                                   placeholder="tucorreo@ejemplo.com"
                                   autocomplete="email"
                                   @bind="loginModel.Email"
                                   @bind:event="oninput" />
                        </div>
                    </div>

                    <div class="field">
                        <label class="field-label">Contraseña</label>
                        <div class="input-wrap">
                            <i class="fas fa-lock input-icon"></i>
                            <input type="@(showLoginPassword ? "text" : "password")"
                                   class="field-input"
                                   placeholder="Tu contraseña"
                                   autocomplete="current-password"
                                   @bind="loginModel.Password"
                                   @bind:event="oninput" />
                            <button type="button"
                                    class="toggle-pass"
                                    tabindex="-1"
                                    @onclick="() => showLoginPassword = !showLoginPassword"
                                    aria-label="Mostrar u ocultar contraseña">
                                <i class="fas @(showLoginPassword ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                    </div>

                    <button class="primary-btn"
                            type="button"
                            @onclick="HandleLogin"
                            disabled="@isLoggingIn">
                        @if (isLoggingIn)
                        {
                            <i class="fas fa-spinner fa-spin"></i>
                            <span>Iniciando...</span>
                        }
                        else
                        {
                            <span>Iniciar sesión</span>
                            <i class="fas fa-arrow-right-to-bracket"></i>
                        }
                    </button>

                    @if (showResendVerification)
                    {
                        <button type="button" class="secondary-btn" @onclick="ResendVerificationEmail">
                            <i class="fas fa-paper-plane"></i>
                            <span>Reenviar correo de verificación</span>
                        </button>
                    }

                    <p class="switch-hint" style="text-align:center;margin-top:8px;">
                        <button type="button" class="link-btn" @onclick="OpenForgotPasswordModal">
                            ¿Olvidaste tu contraseña?
                        </button>
                    </p>

                    <p class="switch-hint">
                        ¿No tienes cuenta?
                        <button type="button" class="link-btn" @onclick='() => SwitchTab("register")'>
                            Regístrate aquí
                        </button>
                    </p>
                </form>
            }
            else
            {
                <form class="auth-form" @onsubmit:preventDefault="true" autocomplete="on">
                    @if (!string.IsNullOrEmpty(registerError))
                    {
                        <div class="auth-alert auth-alert-error">
                            <i class="fas fa-circle-exclamation"></i>
                            <span>@registerError</span>
                        </div>
                    }

                    <div class="field">
                        <label class="field-label">Nombre completo</label>
                        <div class="input-wrap">
                            <i class="fas fa-user input-icon"></i>
                            <input type="text"
                                   class="field-input"
                                   placeholder="Ej. Juan Pérez"
                                   autocomplete="name"
                                   @bind="registerModel.Name"
                                   @bind:event="oninput" />
                        </div>
                    </div>

                    <div class="field">
                        <label class="field-label">Correo electrónico</label>
                        <div class="input-wrap">
                            <i class="fas fa-envelope input-icon"></i>
                            <input type="email"
                                   class="field-input"
                                   placeholder="tucorreo@ejemplo.com"
                                   autocomplete="email"
                                   @bind="registerModel.Email"
                                   @bind:event="oninput" />
                        </div>
                    </div>

                    <div class="field">
                        <label class="field-label">Teléfono</label>
                        <div class="input-wrap">
                            <i class="fas fa-phone input-icon"></i>
                            <input type="tel"
                                   class="field-input"
                                   placeholder="Ej. +52 555 123 4567"
                                   autocomplete="tel"
                                   @bind="registerModel.PhoneNumber"
                                   @bind:event="oninput" />
                        </div>
                    </div>

                    <div class="field">
                        <label class="field-label">Contraseña</label>
                        <div class="input-wrap">
                            <i class="fas fa-lock input-icon"></i>
                            <input type="@(showRegisterPassword ? "text" : "password")"
                                   class="field-input"
                                   placeholder="Mínimo 8 caracteres"
                                   autocomplete="new-password"
                                   @bind="registerModel.Password"
                                   @bind:event="oninput" />
                            <button type="button"
                                    class="toggle-pass"
                                    tabindex="-1"
                                    @onclick="() => showRegisterPassword = !showRegisterPassword"
                                    aria-label="Mostrar u ocultar contraseña">
                                <i class="fas @(showRegisterPassword ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>

                        <ul class="pw-requirements">
                            <li class="@(HasMinLength(registerModel.Password) ? "ok" : "")">
                                <i class="fas @(HasMinLength(registerModel.Password) ? "fa-circle-check" : "fa-circle")"></i>
                                Al menos 8 caracteres
                            </li>
                            <li class="@(HasUpper(registerModel.Password) ? "ok" : "")">
                                <i class="fas @(HasUpper(registerModel.Password) ? "fa-circle-check" : "fa-circle")"></i>
                                Una letra mayúscula
                            </li>
                            <li class="@(HasDigit(registerModel.Password) ? "ok" : "")">
                                <i class="fas @(HasDigit(registerModel.Password) ? "fa-circle-check" : "fa-circle")"></i>
                                Un número
                            </li>
                            <li class="@(HasSymbol(registerModel.Password) ? "ok" : "")">
                                <i class="fas @(HasSymbol(registerModel.Password) ? "fa-circle-check" : "fa-circle")"></i>
                                Un carácter especial
                            </li>
                        </ul>
                    </div>

                    <button class="primary-btn"
                            type="button"
                            @onclick="OnRegisterClick"
                            disabled="@isRegistering">
                        @if (isRegistering)
                        {
                            <i class="fas fa-spinner fa-spin"></i>
                            <span>Registrando...</span>
                        }
                        else
                        {
                            <span>Crear cuenta</span>
                            <i class="fas fa-user-plus"></i>
                        }
                    </button>

                    <p class="switch-hint">
                        ¿Ya tienes cuenta?
                        <button type="button" class="link-btn" @onclick='() => SwitchTab("login")'>
                            Inicia sesión
                        </button>
                    </p>
                </form>
            }
        </div>
    </div>
</div>

@* ---------- Modales ---------- *@

@if (showForgotPasswordModal)
{
    <div class="modal-overlay" @onclick="CloseForgotPasswordModal">
        <div class="modal-box modal-box--sm modal-box--centered" @onclick:stopPropagation="true">
            <div class="modal-icon"><i class="fas fa-key"></i></div>
            <h3>Recuperar contraseña</h3>
            <p class="modal-subtitle">Te enviaremos un enlace para restablecerla.</p>

            <EditForm Model="forgotModel" OnValidSubmit="HandleForgotPassword">
                <DataAnnotationsValidator />

                <div class="field">
                    <div class="input-wrap">
                        <i class="fas fa-envelope input-icon"></i>
                        <InputText class="field-input"
                                   @bind-Value="forgotModel.Email"
                                   placeholder="Tu correo electrónico" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(forgotErrorMsg))
                {
                    <div class="auth-alert auth-alert-error">
                        <i class="fas fa-circle-exclamation"></i>
                        <span>@forgotErrorMsg</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(forgotSuccessMsg))
                {
                    <div class="auth-alert auth-alert-success">
                        <i class="fas fa-circle-check"></i>
                        <span>@forgotSuccessMsg</span>
                    </div>
                }

                <div class="modal-actions">
                    <button class="secondary-btn"
                            type="button"
                            @onclick="CloseForgotPasswordModal">
                        Cancelar
                    </button>
                    <button class="primary-btn"
                            type="submit"
                            disabled="@isForgotSubmitting">
                        @if (isForgotSubmitting)
                        {
                            <i class="fas fa-spinner fa-spin"></i>
                            <span>Enviando...</span>
                        }
                        else
                        {
                            <span>Enviar enlace</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (showVerifyModal)
{
    <div class="modal-overlay" @onclick="CloseVerifyModal">
        <div class="modal-box modal-box--sm modal-box--centered" @onclick:stopPropagation="true">
            <div class="modal-icon success"><i class="fas fa-circle-check"></i></div>
            <h3>¡Listo!</h3>
            <p class="modal-subtitle">@verifyModalMessage</p>
            <div class="modal-actions">
                <button class="primary-btn" @onclick="CloseVerifyModal">
                    Continuar
                </button>
            </div>
        </div>
    </div>
}

@if (showPolicyDialog)
{
    <div class="modal-overlay">
        <div class="modal-box modal-box--sm modal-box--centered" @onclick:stopPropagation="true">
            <div class="modal-icon"><i class="fas fa-file-shield"></i></div>
            <h3>Política de Privacidad</h3>
            <p class="modal-subtitle">
                Para continuar con el registro necesitas aceptar nuestra política de privacidad.
                Tus datos se utilizarán únicamente para el funcionamiento de tu cuenta y los
                pedidos que realices en Ferrexpress.
            </p>
            <div class="modal-actions">
                <button class="secondary-btn" @onclick="DeclinePolicy">
                    Cancelar
                </button>
                <button class="primary-btn" @onclick="AcceptPolicy">
                    Aceptar y continuar
                </button>
            </div>
        </div>
    </div>
}

@code {
    private LoginModel loginModel = new LoginModel();
    private RegisterModel registerModel = new RegisterModel();

    private string activeTab = "login";
    private bool showLoginPassword = false;
    private bool showRegisterPassword = false;

    private string loginError;
    private string registerError;

    private bool isLoggingIn = false;
    private bool isRegistering = false;
    private bool showPolicyDialog = false;
    private bool showVerifyModal = false;
    private string verifyModalMessage;

    private bool showForgotPasswordModal = false;
    private bool isForgotSubmitting = false;
    private string forgotErrorMsg;
    private string forgotSuccessMsg;
    private ForgotPasswordModel forgotModel = new();

    private bool showResendVerification = false;
    private int? pendingVerificationUserId = null;

    private static System.Collections.Concurrent.ConcurrentDictionary<string, int> loginAttempts = new();
    private static System.Collections.Concurrent.ConcurrentDictionary<string, DateTime> lockouts = new();
    private static System.Collections.Concurrent.ConcurrentDictionary<string, DateTime> lastRegistration = new();
    private static System.Collections.Concurrent.ConcurrentDictionary<string, DateTime> lastForgot = new();
    private static System.Collections.Concurrent.ConcurrentDictionary<string, DateTime> lastResend = new();
    private const int RateLimitSeconds = 60;
    private const int MaxLoginAttempts = 5;
    private const int LockoutMinutes = 15;

    private class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Ingresa tu correo electrónico.")]
        [EmailAddress(ErrorMessage = "El correo no tiene un formato válido.")]
        public string Email { get; set; }
    }

    public class LoginModel
    {
        public string Email { get; set; }
        public string Password { get; set; }
    }

    public class RegisterModel
    {
        public string Name { get; set; }
        public string Email { get; set; }
        public string PhoneNumber { get; set; }
        public string Password { get; set; }
        public bool PolicyAccepted { get; set; }
    }

    private void SwitchTab(string tab)
    {
        activeTab = tab;
        loginError = null;
        registerError = null;
        showResendVerification = false;
    }

    private void OpenForgotPasswordModal()
    {
        showForgotPasswordModal = true;
        forgotErrorMsg = null;
        forgotSuccessMsg = null;
        forgotModel = new ForgotPasswordModel { Email = loginModel.Email ?? "" };
    }

    private void CloseForgotPasswordModal()
    {
        showForgotPasswordModal = false;
        forgotErrorMsg = null;
        forgotSuccessMsg = null;
    }

    private async Task HandleForgotPassword()
    {
        if (isForgotSubmitting) return;
        isForgotSubmitting = true;
        forgotErrorMsg = null;
        forgotSuccessMsg = null;

        try
        {
            if (string.IsNullOrWhiteSpace(forgotModel.Email))
            {
                forgotErrorMsg = "Ingresa tu correo electrónico.";
                return;
            }

            var forgotKey = forgotModel.Email.ToLower();
            if (lastForgot.TryGetValue(forgotKey, out var lastForgotTime)
                && (DateTime.UtcNow - lastForgotTime).TotalSeconds < RateLimitSeconds)
            {
                forgotErrorMsg = "Espera un momento antes de intentar de nuevo.";
                return;
            }

            var user = await DbContext.Users
                .FirstOrDefaultAsync(u => u.Email.ToLower() == forgotKey);
            if (user == null)
            {
                lastForgot[forgotKey] = DateTime.UtcNow;
                forgotSuccessMsg = "Si existe una cuenta con ese correo, recibirás un enlace para restablecer tu contraseña.";
                return;
            }

            var oldResets = await DbContext.PasswordResets
                .Where(x => x.UserId == user.Id)
                .ToListAsync();
            DbContext.PasswordResets.RemoveRange(oldResets);

            var token = Guid.NewGuid().ToString("N");
            var pr = new PasswordReset
                {
                    UserId = user.Id,
                    Token = token,
                    ExpiresAt = DateTime.UtcNow.AddHours(2),
                    CreatedAt = DateTime.UtcNow
                };
            DbContext.PasswordResets.Add(pr);
            await DbContext.SaveChangesAsync();

            var link = $"{NavigationManager.BaseUri.TrimEnd('/')}/resetpassword?token={token}";
            var html = BuildEmailTemplate(
                badge: "Recuperar contraseña",
                greeting: $"Hola, {user.Name}",
                intro: "Recibimos una solicitud para restablecer la contraseña de tu cuenta en Ferrexpress. Haz clic en el botón de abajo para crear una nueva contraseña.",
                buttonText: "Restablecer mi contraseña",
                link: link,
                expiresUtc: pr.ExpiresAt,
                securityNote: "Si no solicitaste este cambio, puedes ignorar este correo de forma segura. Tu contraseña actual seguirá funcionando y tu cuenta permanecerá protegida.");
            await EmailSender.SendEmailAsync(user.Email,
                "Recupera tu contraseña en Ferrexpress",
                html);

            lastForgot[forgotKey] = DateTime.UtcNow;
            forgotSuccessMsg = "Listo, revisa tu correo para restablecer tu contraseña.";
        }
        catch
        {
            forgotErrorMsg = "No pudimos enviar el enlace. Inténtalo de nuevo más tarde.";
        }
        finally
        {
            isForgotSubmitting = false;
        }
    }

    private async Task HandleLogin()
    {
        if (isLoggingIn) return;
        isLoggingIn = true;
        loginError = null;
        showResendVerification = false;

        try
        {
            var emailKey = loginModel.Email?.Trim().ToLower() ?? "";

            if (string.IsNullOrWhiteSpace(loginModel.Email) || string.IsNullOrWhiteSpace(loginModel.Password))
            {
                loginError = "Ingresa tu correo y tu contraseña para continuar.";
                return;
            }

            if (lockouts.TryGetValue(emailKey, out var lockoutEnd) && DateTime.UtcNow < lockoutEnd)
            {
                var remaining = (int)(lockoutEnd - DateTime.UtcNow).TotalMinutes + 1;
                loginError = $"Demasiados intentos fallidos. Intenta de nuevo en {remaining} minuto(s).";
                return;
            }

            var user = await DbContext.Users.Include(u => u.Role)
                .FirstOrDefaultAsync(u => u.Email.ToLower() == emailKey);

            if (user == null || !BCrypt.Net.BCrypt.Verify(loginModel.Password, user.Password))
            {
                var attempts = loginAttempts.AddOrUpdate(emailKey, 1, (_, prev) => prev + 1);

                if (attempts >= MaxLoginAttempts)
                {
                    lockouts[emailKey] = DateTime.UtcNow.AddMinutes(LockoutMinutes);
                    loginAttempts.TryRemove(emailKey, out _);
                    loginError = $"Demasiados intentos fallidos. Tu cuenta quedó bloqueada por {LockoutMinutes} minutos.";
                }
                else
                {
                    var remaining = MaxLoginAttempts - attempts;
                    loginError = $"Correo o contraseña incorrectos. Te quedan {remaining} intento(s).";
                }
                return;
            }

            if (!user.EmailConfirmed)
            {
                pendingVerificationUserId = user.Id;
                showResendVerification = true;
                loginError = "Debes verificar tu correo antes de iniciar sesión. Revisa tu bandeja o reenvía el correo de verificación.";
                return;
            }

            loginAttempts.TryRemove(emailKey, out _);
            lockouts.TryRemove(emailKey, out _);

            var claims = new List<Claim> {
                new Claim(ClaimTypes.Name, user.Name),
                new Claim(ClaimTypes.NameIdentifier, user.Id.ToString()),
                new Claim(ClaimTypes.Email, user.Email),
                new Claim(ClaimTypes.Role, user.Role?.Name ?? "User")
            };
            var token = GenerateJwt(claims);
            if (AuthenticationStateProvider is CustomAuthenticationStateProvider cap)
                await cap.SignIn(token);

            NavigationManager.NavigateTo("/");
        }
        catch
        {
            loginError = "Ocurrió un error al iniciar sesión. Inténtalo de nuevo.";
        }
        finally
        {
            isLoggingIn = false;
        }
    }

    private string GenerateJwt(List<Claim> claims)
    {
        var key = new SymmetricSecurityKey(Encoding.UTF8.GetBytes(_configuration["JwtSettings:SecretKey"]));
        var creds = new SigningCredentials(key, SecurityAlgorithms.HmacSha256);
        var jwt = new JwtSecurityToken(
            issuer: _configuration["JwtSettings:Issuer"],
            audience: _configuration["JwtSettings:Audience"],
            claims: claims,
            expires: DateTime.UtcNow.AddHours(8),
            signingCredentials: creds);
        return new JwtSecurityTokenHandler().WriteToken(jwt);
    }

    private void OnRegisterClick()
    {
        if (isRegistering) return;
        registerError = null;

        if (string.IsNullOrWhiteSpace(registerModel.Name)
            || string.IsNullOrWhiteSpace(registerModel.Email)
            || string.IsNullOrWhiteSpace(registerModel.Password)
            || string.IsNullOrWhiteSpace(registerModel.PhoneNumber))
        {
            registerError = "Completa todos los campos para crear tu cuenta.";
            return;
        }

        if (!IsPasswordValid(registerModel.Password))
        {
            registerError = "Tu contraseña debe tener al menos 8 caracteres, una mayúscula, un número y un carácter especial.";
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(registerModel.PhoneNumber.Trim(), @"^\+?[\d\s\-]{8,15}$"))
        {
            registerError = "Ingresa un número de teléfono válido (8 a 15 dígitos).";
            return;
        }

        showPolicyDialog = true;
    }

    private async Task AcceptPolicy()
    {
        registerModel.PolicyAccepted = true;
        showPolicyDialog = false;
        await HandleRegister();
    }

    private void DeclinePolicy()
    {
        registerModel.PolicyAccepted = false;
        showPolicyDialog = false;
    }

    private async Task HandleRegister()
    {
        if (isRegistering) return;
        isRegistering = true;
        registerError = null;

        try
        {
            var emailKey = registerModel.Email.Trim().ToLower();
            if (lastRegistration.TryGetValue(emailKey, out var lastTime)
                && (DateTime.UtcNow - lastTime).TotalSeconds < RateLimitSeconds)
            {
                registerError = "Espera un momento antes de intentar registrarte de nuevo.";
                return;
            }

            if (await DbContext.Users.AnyAsync(u => u.Email.ToLower() == emailKey))
            {
                registerError = "Este correo ya está registrado. Intenta iniciar sesión.";
                return;
            }

            var user = new User
                {
                    Name = registerModel.Name.Trim(),
                    Email = registerModel.Email.Trim(),
                    PhoneNumber = registerModel.PhoneNumber.Trim(),
                    Password = BCrypt.Net.BCrypt.HashPassword(registerModel.Password),
                    CreateTime = DateTime.UtcNow,
                    RoleId = 1,
                    PolicyUser = registerModel.PolicyAccepted,
                    EmailConfirmed = false
                };
            DbContext.Users.Add(user);
            await DbContext.SaveChangesAsync();

            var verifyToken = Guid.NewGuid().ToString("N");
            var verification = new EmailVerification
                {
                    UserId = user.Id,
                    Token = verifyToken,
                    ExpiresAt = DateTime.UtcNow.AddMinutes(30),
                    CreatedAt = DateTime.UtcNow
                };
            DbContext.EmailVerifications.Add(verification);
            await DbContext.SaveChangesAsync();

            var verifyLink = $"{NavigationManager.BaseUri.TrimEnd('/')}/verify?token={verifyToken}";
            var verifyHtml = BuildEmailTemplate(
                badge: "Verificar correo",
                greeting: $"Bienvenido, {user.Name}",
                intro: "Gracias por registrarte en Ferrexpress. Para activar tu cuenta y comenzar a usar nuestros servicios, confirma tu dirección de correo haciendo clic en el botón de abajo.",
                buttonText: "Verificar mi correo",
                link: verifyLink,
                expiresUtc: verification.ExpiresAt,
                securityNote: "Si no creaste una cuenta en Ferrexpress, puedes ignorar este mensaje. Nadie podrá acceder a la cuenta hasta que el correo sea verificado.");
            try
            {
                await EmailSender.SendEmailAsync(user.Email, "Verifica tu correo", verifyHtml);
            }
            catch
            {
                // Si falla el envío, el usuario puede reenviar desde el login.
            }

            lastRegistration[emailKey] = DateTime.UtcNow;
            pendingVerificationUserId = user.Id;
            registerModel = new RegisterModel();
            verifyModalMessage = "Tu cuenta fue creada. Revisa tu correo para verificar tu cuenta antes de iniciar sesión.";
            showVerifyModal = true;
            showResendVerification = true;
            activeTab = "login";
        }
        catch
        {
            registerError = "Ocurrió un error durante el registro. Inténtalo de nuevo.";
        }
        finally
        {
            isRegistering = false;
        }
    }

    private void CloseVerifyModal()
    {
        showVerifyModal = false;
    }

    private async Task ResendVerificationEmail()
    {
        if (!pendingVerificationUserId.HasValue) return;

        var resendKey = pendingVerificationUserId.Value.ToString();
        if (lastResend.TryGetValue(resendKey, out var lastResendTime)
            && (DateTime.UtcNow - lastResendTime).TotalSeconds < RateLimitSeconds)
        {
            loginError = "Espera un momento antes de reenviar el correo.";
            return;
        }

        var user = await DbContext.Users.Include(u => u.Role)
            .FirstOrDefaultAsync(u => u.Id == pendingVerificationUserId.Value);
        if (user == null || user.EmailConfirmed) return;

        var oldTokens = await DbContext.EmailVerifications
            .Where(ev => ev.UserId == user.Id)
            .ToListAsync();
        DbContext.EmailVerifications.RemoveRange(oldTokens);

        var token = Guid.NewGuid().ToString("N");
        var ev2 = new EmailVerification
            {
                UserId = user.Id,
                Token = token,
                ExpiresAt = DateTime.UtcNow.AddMinutes(30),
                CreatedAt = DateTime.UtcNow
            };
        DbContext.EmailVerifications.Add(ev2);
        await DbContext.SaveChangesAsync();

        var link = $"{NavigationManager.BaseUri.TrimEnd('/')}/verify?token={token}";
        var html = BuildEmailTemplate(
            badge: "Verificar correo",
            greeting: $"Bienvenido, {user.Name}",
            intro: "Gracias por registrarte en Ferrexpress. Para activar tu cuenta y comenzar a usar nuestros servicios, confirma tu dirección de correo haciendo clic en el botón de abajo.",
            buttonText: "Verificar mi correo",
            link: link,
            expiresUtc: ev2.ExpiresAt,
            securityNote: "Si no creaste una cuenta en Ferrexpress, puedes ignorar este mensaje. Nadie podrá acceder a la cuenta hasta que el correo sea verificado.");

        try
        {
            await EmailSender.SendEmailAsync(user.Email, "Verifica tu correo", html);
            lastResend[resendKey] = DateTime.UtcNow;
            showResendVerification = false;
            loginError = null;
            verifyModalMessage = "Se ha reenviado el correo de verificación. Revisa tu bandeja.";
            showVerifyModal = true;
        }
        catch
        {
            loginError = "No pudimos reenviar el correo. Inténtalo más tarde.";
        }
    }

    private static bool IsPasswordValid(string password)
    {
        if (string.IsNullOrEmpty(password) || password.Length < 8) return false;
        return password.Any(char.IsUpper) && password.Any(char.IsDigit)
            && password.Any(c => !char.IsLetterOrDigit(c));
    }

    private static bool HasMinLength(string p) => !string.IsNullOrEmpty(p) && p.Length >= 8;
    private static bool HasUpper(string p) => !string.IsNullOrEmpty(p) && p.Any(char.IsUpper);
    private static bool HasDigit(string p) => !string.IsNullOrEmpty(p) && p.Any(char.IsDigit);
    private static bool HasSymbol(string p) => !string.IsNullOrEmpty(p) && p.Any(c => !char.IsLetterOrDigit(c));

    private static string BuildEmailTemplate(
        string badge,
        string greeting,
        string intro,
        string buttonText,
        string link,
        DateTime expiresUtc,
        string securityNote)
    {
        var safeBadge = System.Net.WebUtility.HtmlEncode(badge);
        var safeGreeting = System.Net.WebUtility.HtmlEncode(greeting);
        var safeIntro = System.Net.WebUtility.HtmlEncode(intro);
        var safeButton = System.Net.WebUtility.HtmlEncode(buttonText);
        var safeLink = System.Net.WebUtility.HtmlEncode(link);
        var safeSecurity = System.Net.WebUtility.HtmlEncode(securityNote);
        var expires = expiresUtc.ToString("yyyy-MM-dd HH:mm");
        var year = DateTime.UtcNow.Year;

        return $@"<!DOCTYPE html>
<html lang=""es"">
<head>
<meta charset=""UTF-8"">
<meta name=""viewport"" content=""width=device-width,initial-scale=1"">
<title>{safeBadge}</title>
</head>
<body style=""margin:0;padding:0;background-color:#f4f4f7;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:#2d2d2d;"">
  <table role=""presentation"" width=""100%"" cellpadding=""0"" cellspacing=""0"" style=""background-color:#f4f4f7;padding:32px 12px;"">
    <tr>
      <td align=""center"">
        <table role=""presentation"" width=""600"" cellpadding=""0"" cellspacing=""0"" style=""max-width:600px;width:100%;background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.06);"">
          <tr>
            <td style=""background-color:#1a1a2e;padding:28px 32px;"">
              <table role=""presentation"" width=""100%"" cellpadding=""0"" cellspacing=""0"">
                <tr>
                  <td style=""vertical-align:middle;"">
                    <span style=""display:inline-block;font-size:22px;font-weight:700;color:#ffffff;letter-spacing:0.5px;"">FERREX<span style=""color:#F5C144;"">PRESS</span></span>
                  </td>
                  <td align=""right"" style=""vertical-align:middle;"">
                    <span style=""display:inline-block;background-color:#F5C144;color:#1a1a2e;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;padding:6px 12px;border-radius:20px;"">{safeBadge}</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style=""padding:40px 32px 24px 32px;"">
              <h1 style=""margin:0 0 16px 0;font-size:24px;font-weight:600;color:#1a1a2e;line-height:1.3;"">{safeGreeting}</h1>
              <p style=""margin:0 0 24px 0;font-size:15px;line-height:1.6;color:#4a4a5e;"">{safeIntro}</p>
              <table role=""presentation"" cellpadding=""0"" cellspacing=""0"" style=""margin:8px 0 28px 0;"">
                <tr>
                  <td style=""background-color:#dc3545;border-radius:8px;"">
                    <a href=""{safeLink}"" style=""display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:8px;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica,Arial,sans-serif;"">{safeButton}</a>
                  </td>
                </tr>
              </table>
              <table role=""presentation"" width=""100%"" cellpadding=""0"" cellspacing=""0"" style=""background-color:#fff8e7;border-left:3px solid #F5C144;border-radius:4px;margin-bottom:24px;"">
                <tr>
                  <td style=""padding:12px 16px;font-size:13px;color:#7a5a00;"">
                    <strong>Este enlace expira:</strong> {expires} UTC
                  </td>
                </tr>
              </table>
              <p style=""margin:0 0 8px 0;font-size:13px;color:#6b7280;"">Si el botón no funciona, copia y pega este enlace en tu navegador:</p>
              <p style=""margin:0 0 20px 0;font-size:12px;word-break:break-all;""><a href=""{safeLink}"" style=""color:#3b82f6;text-decoration:underline;"">{safeLink}</a></p>
              <p style=""margin:0;padding-top:20px;border-top:1px solid #eeeef2;font-size:13px;color:#6b7280;line-height:1.5;"">{safeSecurity}</p>
            </td>
          </tr>
          <tr>
            <td style=""background-color:#fafafa;padding:20px 32px;text-align:center;border-top:1px solid #eeeef2;"">
              <p style=""margin:0 0 6px 0;font-size:12px;color:#9ca3af;"">&copy; {year} Ferrexpress. Todos los derechos reservados.</p>
              <p style=""margin:0;font-size:11px;color:#9ca3af;"">Este es un correo automático, por favor no respondas a este mensaje.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>";
    }
}

