@page "/verify"
@using FerrexWeb.Models
@using FerrexWeb.Services
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager

<div class="verify-container">
    <div class="verify-card">
        @if (processing)
        {
            <div class="verify-icon">
                <i class="fas fa-spinner fa-spin"></i>
            </div>
            <h3>Verificando tu correo...</h3>
            <p>Por favor espera.</p>
        }
        else if (success)
        {
            <div class="verify-icon success">
                <i class="fas fa-check-circle"></i>
            </div>
            <h3>¡Correo confirmado!</h3>
            <p>Tu cuenta ha sido verificada exitosamente.</p>
            <button class="verify-button" @onclick='() => NavigationManager.NavigateTo("/userinfo")'>
                Iniciar sesión
            </button>
        }
        else
        {
            <div class="verify-icon error">
                <i class="fas fa-times-circle"></i>
            </div>
            <h3>Error de verificación</h3>
            <p>@message</p>
            <button class="verify-button" @onclick='() => NavigationManager.NavigateTo("/userinfo")'>
                Ir al inicio de sesión
            </button>
        }
    </div>
</div>

@code {
    bool processing = true;
    bool success = false;
    string message = "";

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        var token = Microsoft.AspNetCore.WebUtilities
                        .QueryHelpers.ParseQuery(uri.Query)
                        .TryGetValue("token", out var t) ? t.ToString() : null;

        if (string.IsNullOrEmpty(token))
        {
            message = "Token inválido.";
        }
        else
        {
            try
            {
                var ev = await DbContext.EmailVerifications
                            .AsTracking()
                            .Include(ev => ev.User)
                            .FirstOrDefaultAsync(ev => ev.Token == token);

                if (ev == null)
                    message = "Enlace inválido o ya fue utilizado.";
                else if (ev.ExpiresAt < DateTime.UtcNow)
                    message = "El enlace ha expirado. Intenta iniciar sesión y usa la opción de reenviar verificación.";
                else
                {
                    ev.User.EmailConfirmed = true;
                    DbContext.EmailVerifications.Remove(ev);
                    await DbContext.SaveChangesAsync();
                    success = true;
                }
            }
            catch
            {
                message = "Ocurrió un error al verificar tu correo. Inténtalo de nuevo.";
            }
        }

        processing = false;
    }
}

<style>
    .verify-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 20px;
        font-family: 'Jost', sans-serif;
    }

    .verify-card {
        background: #fff;
        border-radius: 15px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.1);
        padding: 40px;
        text-align: center;
        max-width: 450px;
        width: 100%;
    }

        .verify-card h3 {
            margin: 15px 0 10px;
            font-size: 1.5em;
            color: #333;
        }

        .verify-card p {
            color: #666;
            font-size: 1em;
            margin-bottom: 20px;
        }

    .verify-icon {
        font-size: 3em;
        color: #F5C144;
        margin-bottom: 10px;
    }

        .verify-icon.success {
            color: #28a745;
        }

        .verify-icon.error {
            color: #dc3545;
        }

    .verify-button {
        display: inline-block;
        padding: 12px 30px;
        background: #F5C144;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 1em;
        font-weight: bold;
        cursor: pointer;
        transition: background 0.3s;
    }

        .verify-button:hover {
            background: #000;
        }

    /* Tablet */
    @@media (max-width: 768px) {
        .verify-card {
            padding: 30px 25px;
        }
    }

    /* Movil */
    @@media (max-width: 480px) {
        .verify-container {
            padding: 15px 10px;
        }

        .verify-card {
            padding: 25px 15px;
            border-radius: 10px;
        }

            .verify-card h3 {
                font-size: 1.3em;
            }

        .verify-icon {
            font-size: 2.5em;
        }

        .verify-button {
            width: 100%;
            padding: 12px 20px;
        }
    }
</style>
