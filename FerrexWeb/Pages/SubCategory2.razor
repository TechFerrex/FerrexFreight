@page "/subcategory2list/{SubCategoryId:int}"
@using FerrexWeb.Models
@using FerrexWeb.Services
@inject SubCategory2Service SubCategory2Service
@inject ProductService ProductService
@inject NavigationManager NavigationManager

<h1 class="text-center my-4">Subcategorías</h1>

@if (subcategories2 == null || firstProductMap == null)
{
    <div class="d-flex justify-content-center align-items-center full-height">
        <div class="spinner-border" role="status" style="color: #F5C144;">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else
{
        <div class="container">
    <div class="row">
        @foreach (var subcat in subcategories2)
        {
            if (firstProductMap.TryGetValue(subcat.id_subcategory2, out var firstProduct))
            {
                <div class="col-12 col-md-4 mb-4">
                    <div class="card product-card h-100">
                        <img src="@firstProduct.ImageUrl" alt="@subcat.name" class="card-img-top" />
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@subcat.name</h5>
                            <div class="mt-auto">
                                <a href="@($"/productdetails/{firstProduct.IdProducto}")" class="btn custom-btn">
                                    Ver Producto
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
    </div>
}

@code {
    [Parameter]
    public int SubCategoryId { get; set; }

    private List<Subcategory2> subcategories2;
    private Dictionary<int, Products> firstProductMap;

    protected override async Task OnInitializedAsync()
    {
        subcategories2 = await SubCategory2Service.GetSubCategory2BySubCategoryIdAsync(SubCategoryId);

        var sub2Ids = subcategories2.Select(s => s.id_subcategory2).ToList();
        firstProductMap = await ProductService.GetFirstProductBySubCategory2IdsAsync(sub2Ids);
    }
}


<style>
    .product-card {
        border: none;
        transition: transform 0.3s, box-shadow 0.3s;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        border-radius: 8px;
    }

        .product-card:hover {
            transform: scale(1.03);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }

    .card-img-top {
        width: 100%;
        height: 160px;
        object-fit: cover;
        border-top-left-radius: 8px;
        border-top-right-radius: 8px;
    }

    .card-body {
        padding: 0.75rem;
    }

    .card-title {
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: #333;
    }

    .card-text {
        font-size: 0.8rem;
        color: #555;
    }

    .btn.custom-btn {
        background-color: #F5C144;
        border: none;
        color: #000;
        padding: 0.4rem 0.8rem;
        font-size: 0.8rem;
        transition: background-color 0.3s;
        border-radius: 4px;
    }

        .btn.custom-btn:hover {
            background-color: #e0ac35;
            color: #fff;
        }

    /* Tablet */
    @@media (max-width: 768px) {
        .col-md-4 {
            flex: 0 0 50%;
            max-width: 50%;
        }

        .card-img-top {
            height: 130px;
        }

        .btn.custom-btn {
            min-height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
    }

    /* Movil */
    @@media (max-width: 480px) {
        .col-12.col-md-4 {
            flex: 0 0 100%;
            max-width: 100%;
        }

        .card-img-top {
            height: 120px;
        }

        .card-title {
            font-size: 0.85rem;
        }

        .btn.custom-btn {
            width: 100%;
            padding: 10px;
            font-size: 0.8rem;
        }

        .card-body {
            padding: 0.6rem;
        }

        .product-card:hover {
            transform: none;
        }
    }
</style>
