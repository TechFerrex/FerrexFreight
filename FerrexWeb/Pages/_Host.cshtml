@page "/"
@using Microsoft.AspNetCore.Components.Web
@namespace FerrexWeb.Pages
@inject IConfiguration Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <base href="~/" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- CSS -->
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="css/site.css" />
    <link rel="stylesheet" href="css/responsive.css" />
    <link rel="icon" type="image/x-icon" href="logotornillo.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap">
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css"
          integrity="sha384-…"
          crossorigin="anonymous">
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
          integrity="sha384-…"
          crossorigin="anonymous">

    <!-- Preload hero images -->
    <link rel="preload" as="image" href="/images/banner1.webp" fetchpriority="high">
    <link rel="preload" as="image" href="/images/banner2.webp" fetchpriority="high">
    <link rel="preload" as="image" href="/images/banner3.webp" fetchpriority="high">

    <!-- Custom inline CSS -->
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0,'wght' 400,'GRAD' 0,'opsz' 24;
            font-size: 1.5rem;
            vertical-align: middle;
        }

        /* Hide the default Blazor reconnection modal */
        #components-reconnect-modal {
            display: none !important;
        }
    </style>

    <!-- HeadOutlet -->
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    <component type="typeof(App)" render-mode="Server" />

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            Hubo un error, intente de nuevo o reinicie la página.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Recargar</a>
        <a class="dismiss">✖</a>
    </div>

    <!-- Global variables -->
    <script>
        window._googleMapsApiKey = "@Configuration["GoogleMaps:ApiKey"]";
    </script>

    <script defer src="js/mapsInterop.js"></script>
    <script defer src="js/quotationsModalFreight.js"></script>
    <script defer src="js/customScripts.js"></script>
    <script defer src="js/freightAdminHelpers.js"></script>
    <script defer src="js/FileUtil.js"></script>
    <script defer src="js/site.js"></script>

    <script async defer
            src="https://maps.googleapis.com/maps/api/js?key=@Configuration["GoogleMaps:ApiKey"]&libraries=places&callback=initMap">
    </script>
    <script defer src="https://code.jquery.com/jquery-3.7.1.min.js"
            integrity="sha384-…"
            crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"
            integrity="sha384-…"
            crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js"
            integrity="sha384-…"
            crossorigin="anonymous"></script>
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.10.4/gsap.min.js"
            integrity="sha384-…"
            crossorigin="anonymous"></script>

    <!-- Tu bundle minificado -->
    <script defer src="dist/app.bundle.js"></script>

    <!-- Framework -->
    <script src="_framework/blazor.server.js" autostart="false"></script>
    <script>
        // Blazor reconnection: retry aggressively before showing UI
        Blazor.start({
            reconnectionOptions: {
                maxRetries: 30,
                retryIntervalMilliseconds: 2000
            },
            reconnectionHandler: {
                onConnectionDown: (options, error) => {
                    // Silently retry — don't show the default modal immediately
                    console.warn('Blazor connection lost, retrying…');
                },
                onConnectionUp: () => {
                    // Connection restored — reload to ensure fresh state
                    location.reload();
                }
            }
        });
    </script>

    <!--Start of Tawk.to Script-->
    <script type="text/javascript">
        var Tawk_API = Tawk_API || {}, Tawk_LoadStart = new Date();
        (function () {
            var s1 = document.createElement("script"), s0 = document.getElementsByTagName("script")[0];
            s1.async = true;
            s1.src = 'https://embed.tawk.to/69d6726b6839171c36f07332/1jlmqtsl8';
            s1.charset = 'UTF-8';
            s1.setAttribute('crossorigin', '*');
            s0.parentNode.insertBefore(s1, s0);
        })();
    </script>
    <!--End of Tawk.to Script-->
</body>
</html>
