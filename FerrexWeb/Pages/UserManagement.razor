@page "/usersmanagement"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "SuperAdmin")]
@using FerrexWeb.Services
@inject ApplicationDbContext DbContext

<div class="user-management-container">
    <div class="page-header">
        <h3><i class="fas fa-users"></i> Gestión de Usuarios</h3>
        <button class="btn btn-success" @onclick="OpenAddUserModal">
            <i class="fas fa-user-plus"></i> Agregar Usuario
        </button>
    </div>

    @if (users == null)
    {
        <div class="loader-container">
            <div class="loader">
                <div class="circle"></div>
                <div class="circle"></div>
                <div class="circle"></div>
            </div>
            <p>Cargando usuarios...</p>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header">
                <div class="search-box">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" class="form-control search-input" placeholder="Buscar usuarios..." 
                           @bind-value="searchTerm" @bind-value:event="oninput" @onkeyup="FilterUsers" />
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <button class="btn btn-sm clear-search" @onclick="ClearSearch">
                            <i class="fas fa-times"></i>
                        </button>
                    }
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th @onclick='() => SortUsers("Name")'>
                                    Nombre <SortIcon Field="Name" CurrentSortField="@currentSortField" IsAscending="@isAscending" />
                                </th>
                                <th @onclick='() => SortUsers("Email")'>
                                    Email <SortIcon Field="Email" CurrentSortField="@currentSortField" IsAscending="@isAscending" />
                                </th>
                                <th @onclick='() => SortUsers("Role")'>
                                    Rol <SortIcon Field="Role" CurrentSortField="@currentSortField" IsAscending="@isAscending" />
                                </th>
                                <th>Contraseña</th>
                                <th @onclick='() => SortUsers("PhoneNumber")'>
                                    Teléfono <SortIcon Field="PhoneNumber" CurrentSortField="@currentSortField" IsAscending="@isAscending" />
                                </th>
                                <th @onclick='() => SortUsers("CreateTime")'>
                                    Fecha de Creación <SortIcon Field="CreateTime" CurrentSortField="@currentSortField" IsAscending="@isAscending" />
                                </th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (pagedUsers.Count == 0)
                            {
                                <tr>
                                    <td colspan="7" class="text-center">No se encontraron usuarios</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var user in pagedUsers)
                                {
                                    <tr>
                                        <td>@user.Name</td>
                                        <td>@user.Email</td>
                                        <td><span class="badge @GetRoleBadgeClass(user.Role?.Name)">@user.Role?.Name</span></td>
                                        <td><span class="password-mask">••••••••</span></td>
                                        <td>@user.PhoneNumber</td>
                                        <td>@user.CreateTime.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            <div class="action-buttons">
                                                <button class="btn btn-sm btn-outline-primary" title="Editar usuario" @onclick="() => EditUser(user)">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" title="Eliminar usuario" @onclick="() => ConfirmDelete(user)">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="pagination-container">
                    <div class="pagination-info">
                        Mostrando @filteredUsers.Count de @users.Count usuarios
                    </div>
                    @if (users.Count > itemsPerPage)
                    {
                        <div class="pagination">
                            <button class="btn btn-sm @(currentPage == 1 ? "btn-secondary disabled" : "btn-outline-primary")" 
                                    @onclick="PreviousPage" disabled="@(currentPage == 1)">
                                <i class="fas fa-chevron-left"></i>
                            </button>
                            
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                var pageNumber = i;
                                <button class="btn btn-sm @(currentPage == pageNumber ? "btn-primary" : "btn-outline-primary")" 
                                        @onclick="() => GoToPage(pageNumber)">
                                    @pageNumber
                                </button>
                            }
                            
                            <button class="btn btn-sm @(currentPage == totalPages ? "btn-secondary disabled" : "btn-outline-primary")" 
                                    @onclick="NextPage" disabled="@(currentPage == totalPages)">
                                <i class="fas fa-chevron-right"></i>
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal de Edición de Usuario -->
@if (showEditModal && userToEdit != null)
{
    <div class="modal-backdrop show"></div>
    <div class="modal fade show" style="display: block;" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-user-edit"></i> Editar Usuario
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@userToEdit" OnValidSubmit="SaveUser">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        
                        <div class="form-group mb-3">
                            <label for="userName">Nombre</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user"></i></span>
                                <InputText id="userName" @bind-Value="userToEdit.Name" class="form-control" placeholder="Nombre completo" />
                            </div>
                            <ValidationMessage For="@(() => userToEdit.Name)" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="userEmail">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                <InputText id="userEmail" @bind-Value="userToEdit.Email" class="form-control" placeholder="correo@ejemplo.com" />
                            </div>
                            <ValidationMessage For="@(() => userToEdit.Email)" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="userPhone">Teléfono</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                                <InputText id="userPhone" @bind-Value="userToEdit.PhoneNumber" class="form-control" placeholder="Número de teléfono" />
                            </div>
                            <ValidationMessage For="@(() => userToEdit.PhoneNumber)" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="userPassword">Nueva Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                <InputText id="userPassword" type="@(showPassword ? "text" : "password")" 
                                           @bind-Value="userToEdit.NewPassword" class="form-control" 
                                           placeholder="Dejar en blanco para mantener la actual" />
                                <button type="button" class="btn btn-outline-secondary" @onclick="TogglePasswordVisibility">
                                    <i class="fas @(showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                </button>
                            </div>
                            <small class="form-text text-muted">Dejar en blanco si no desea cambiar la contraseña.</small>
                        </div>
                        
                        <div class="form-group mb-3">
                            <label>Rol actual: <span class="badge @GetRoleBadgeClass(userToEdit.Role?.Name)">@userToEdit.Role?.Name</span></label>
                            <div class="mt-2">
                                <small class="form-text text-muted">El rol no puede modificarse en esta pantalla.</small>
                            </div>
                        </div>
                        
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModals">Cancelar</button>
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save"></i> Guardar Cambios
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal de Confirmación de Eliminación -->
@if (showDeleteModal && userToDelete != null)
{
    <div class="modal-backdrop show"></div>
    <div class="modal fade show" style="display: block;" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-exclamation-triangle text-danger"></i> Confirmar Eliminación</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <p>¿Está seguro que desea eliminar al usuario <strong>@userToDelete.Name</strong>?</p>
                    <p class="text-danger"><i class="fas fa-exclamation-circle"></i> Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModals">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteUser">
                        <i class="fas fa-trash-alt"></i> Eliminar Usuario
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal de Añadir Usuario -->
@if (showAddModal)
{
    <div class="modal-backdrop show"></div>
    <div class="modal fade show" style="display: block;" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-user-plus"></i> Añadir Nuevo Usuario</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle"></i> @errorMessage
                        </div>
                    }
                    <EditForm Model="@newUser" OnValidSubmit="AddUser">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="form-group mb-3">
                            <label for="newUserName">Nombre</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user"></i></span>
                                <InputText id="newUserName" @bind-Value="newUser.Name" class="form-control" placeholder="Nombre completo" />
                            </div>
                            <ValidationMessage For="@(() => newUser.Name)" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="newUserEmail">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                <InputText id="newUserEmail" @bind-Value="newUser.Email" class="form-control" placeholder="correo@ejemplo.com" />
                            </div>
                            <ValidationMessage For="@(() => newUser.Email)" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="newUserPhone">Teléfono</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                                <InputText id="newUserPhone" @bind-Value="newUser.PhoneNumber" class="form-control" placeholder="Número de teléfono" />
                            </div>
                            <ValidationMessage For="@(() => newUser.PhoneNumber)" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="newUserPassword">Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                <InputText id="newUserPassword" type="@(showPassword ? "text" : "password")" 
                                           @bind-Value="newUser.NewPassword" class="form-control" placeholder="Contraseña" />
                                <button type="button" class="btn btn-outline-secondary" @onclick="TogglePasswordVisibility">
                                    <i class="fas @(showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => newUser.NewPassword)" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="userRole">Rol</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user-tag"></i></span>
                                <InputSelect id="userRole" @bind-Value="newUser.RoleId" class="form-select">
                                    @foreach (var role in availableRoles)
                                    {
                                        <option value="@role.Id">@role.Name</option>
                                    }
                                </InputSelect>
                            </div>
                            <ValidationMessage For="@(() => newUser.RoleId)" />
                        </div>
                        
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModals">Cancelar</button>
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-user-plus"></i> Crear Usuario
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<User> users;
    private List<User> filteredUsers = new List<User>();
    private List<User> pagedUsers = new List<User>();
    private User userToEdit;
    private User userToDelete;
    private User newUser = new User();
    private bool showEditModal = false;
    private bool showDeleteModal = false;
    private bool showAddModal = false;
    private bool showPassword = false;
    private string searchTerm = "";
    private string errorMessage = "";

    // Paginación
    private int currentPage = 1;
    private int itemsPerPage = 10;
    private int totalPages => (int)Math.Ceiling(filteredUsers.Count / (double)itemsPerPage);

    // Ordenamiento
    private string currentSortField = "Name";
    private bool isAscending = true;

    // Roles disponibles (se cargan de la BD)
    private List<Role> availableRoles = new List<Role>();

    protected override async Task OnInitializedAsync()
    {
        availableRoles = await DbContext.Roles.ToListAsync();
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        users = await DbContext.Users.Include(u => u.Role).ToListAsync();
        FilterUsers();
        SortUsers(currentSortField);
    }

    private void FilterUsers()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredUsers = users.ToList();
        }
        else
        {
            filteredUsers = users
                .Where(u =>
                    (u.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (u.Email?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (u.Role?.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (u.PhoneNumber?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
                .ToList();
        }

        // Reaplicar ordenamiento
        SortUsers(currentSortField, updateSortDirection: false);

        // Restablecer a primera página si el filtro cambia
        currentPage = 1;

        // Aplicar paginación
        ApplyPagination();
    }

    private void ApplyPagination()
    {
        pagedUsers = filteredUsers
            .Skip((currentPage - 1) * itemsPerPage)
            .Take(itemsPerPage)
            .ToList();
    }

    private void ClearSearch()
    {
        searchTerm = "";
        FilterUsers();
    }

    private void SortUsers(string field, bool updateSortDirection = true)
    {
        if (updateSortDirection && field == currentSortField)
        {
            isAscending = !isAscending;
        }

        currentSortField = field;

        switch (field)
        {
            case "Name":
                filteredUsers = isAscending
                    ? filteredUsers.OrderBy(u => u.Name).ToList()
                    : filteredUsers.OrderByDescending(u => u.Name).ToList();
                break;
            case "Email":
                filteredUsers = isAscending
                    ? filteredUsers.OrderBy(u => u.Email).ToList()
                    : filteredUsers.OrderByDescending(u => u.Email).ToList();
                break;
            case "Role":
                filteredUsers = isAscending
                    ? filteredUsers.OrderBy(u => u.Role?.Name).ToList()
                    : filteredUsers.OrderByDescending(u => u.Role?.Name).ToList();
                break;
            case "PhoneNumber":
                filteredUsers = isAscending
                    ? filteredUsers.OrderBy(u => u.PhoneNumber ?? "").ToList()
                    : filteredUsers.OrderByDescending(u => u.PhoneNumber ?? "").ToList();
                break;
            case "CreateTime":
                filteredUsers = isAscending
                    ? filteredUsers.OrderBy(u => u.CreateTime).ToList()
                    : filteredUsers.OrderByDescending(u => u.CreateTime).ToList();
                break;
            default:
                filteredUsers = isAscending
                    ? filteredUsers.OrderBy(u => u.Name).ToList()
                    : filteredUsers.OrderByDescending(u => u.Name).ToList();
                break;
        }

        // Aplicar paginación después de ordenar
        ApplyPagination();
    }

    private void EditUser(User user)
    {
        userToEdit = new User
        {
            Id = user.Id,
            Name = user.Name,
            Email = user.Email,
            PhoneNumber = user.PhoneNumber,
            RoleId = user.RoleId,
            Role = user.Role,
            CreateTime = user.CreateTime,
            NewPassword = ""
        };
        showEditModal = true;
    }

    private void ConfirmDelete(User user)
    {
        userToDelete = user;
        showDeleteModal = true;
    }

    private void CloseModals()
    {
        showEditModal = false;
        showDeleteModal = false;
        showAddModal = false;
        userToEdit = null;
        userToDelete = null;
    }

    private async Task SaveUser()
    {
        try
        {
            var userInDb = await DbContext.Users.FindAsync(userToEdit.Id);
            if (userInDb != null)
            {
                userInDb.Name = userToEdit.Name;
                userInDb.Email = userToEdit.Email;
                userInDb.PhoneNumber = userToEdit.PhoneNumber;
                
                if (!string.IsNullOrWhiteSpace(userToEdit.NewPassword))
                {
                    // Hash de la nueva contraseña usando BCrypt
                    userInDb.Password = BCrypt.Net.BCrypt.HashPassword(userToEdit.NewPassword);
                }
                
                DbContext.Users.Update(userInDb);
                await DbContext.SaveChangesAsync();
                
                // Notificación (implementar servicio de notificaciones)
                // NotificationService.Success("Usuario actualizado con éxito");
                
                CloseModals();
                await LoadUsers();
            }
        }
        catch (Exception ex)
        {
            // Manejo de errores (implementar servicio de notificaciones)
            // NotificationService.Error($"Error al actualizar usuario: {ex.Message}");
            Console.WriteLine($"Error actualizando usuario: {ex.Message}");
        }
    }

    private async Task DeleteUser()
    {
        try
        {
            if (userToDelete != null)
            {
                var userInDb = await DbContext.Users.FindAsync(userToDelete.Id);
                if (userInDb != null)
                {
                    DbContext.Users.Remove(userInDb);
                    await DbContext.SaveChangesAsync();
                    
                    // Notificación (implementar servicio de notificaciones)
                    // NotificationService.Success("Usuario eliminado con éxito");
                    
                    CloseModals();
                    await LoadUsers();
                }
            }
        }
        catch (Exception ex)
        {
            // Manejo de errores (implementar servicio de notificaciones)
            // NotificationService.Error($"Error al eliminar usuario: {ex.Message}");
            Console.WriteLine($"Error eliminando usuario: {ex.Message}");
        }
    }

    private async Task AddUser()
    {
        errorMessage = "";

        try
        {
            if (newUser == null || string.IsNullOrWhiteSpace(newUser.NewPassword))
            {
                errorMessage = "La contraseña es requerida.";
                return;
            }

            if (string.IsNullOrWhiteSpace(newUser.Name) || string.IsNullOrWhiteSpace(newUser.Email))
            {
                errorMessage = "Nombre y email son requeridos.";
                return;
            }

            // Validar email duplicado (case-insensitive)
            var emailExists = await DbContext.Users.AnyAsync(u => u.Email.ToLower() == newUser.Email.ToLower());
            if (emailExists)
            {
                errorMessage = "Ya existe un usuario con ese email.";
                return;
            }

            var user = new User
            {
                Name = newUser.Name,
                Email = newUser.Email,
                PhoneNumber = newUser.PhoneNumber ?? "",
                RoleId = newUser.RoleId > 0 ? newUser.RoleId : 1,
                CreateTime = DateTime.Now,
                Password = BCrypt.Net.BCrypt.HashPassword(newUser.NewPassword),
                EmailConfirmed = true // Admin crea usuarios ya confirmados
            };

            await DbContext.Users.AddAsync(user);
            await DbContext.SaveChangesAsync();

            CloseModals();
            await LoadUsers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al crear usuario: {ex.Message}";
            Console.WriteLine($"Error creando usuario: {ex.Message}");
        }
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private string GetRoleBadgeClass(string role)
    {
        return role switch
        {
            "SuperAdmin" => "bg-danger",
            "Admin" => "bg-warning",
            "User" => "bg-info",
            _ => "bg-secondary"
        };
    }

    // Métodos de paginación
    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            ApplyPagination();
        }
    }

    private void NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            ApplyPagination();
        }
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            ApplyPagination();
        }
    }

    private void OpenAddUserModal()
    {
        newUser = new User { RoleId = 1, EmailConfirmed = true };
        errorMessage = "";
        showAddModal = true;
    }
}

<!-- Componente para iconos de ordenamiento -->
@code {
    public class SortIcon : ComponentBase
    {
        [Parameter] public string Field { get; set; }
        [Parameter] public string CurrentSortField { get; set; }
        [Parameter] public bool IsAscending { get; set; }

        protected override void BuildRenderTree(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder)
        {
            if (Field == CurrentSortField)
            {
                builder.OpenElement(0, "i");
                builder.AddAttribute(1, "class", IsAscending ? "fas fa-sort-up ms-1" : "fas fa-sort-down ms-1");
                builder.CloseElement();
            }
            else
            {
                builder.OpenElement(0, "i");
                builder.AddAttribute(1, "class", "fas fa-sort ms-1 text-muted");
                builder.CloseElement();
            }
        }
    }
}

<style>
    /* Estilos generales */
    .user-management-container {
        padding: 1rem;
        max-width: 1400px;
        margin: 0 auto;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #e9ecef;
    }

    .page-header h3 {
        margin: 0;
        color: #2c3e50;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Loader */
    .loader-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 3rem 0;
    }

    .loader {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 1rem;
    }

    .circle {
        width: 12px;
        height: 12px;
        background-color: #3498db;
        border-radius: 50%;
        margin: 0 6px;
        animation: bounce 1.4s infinite ease-in-out both;
    }

    .circle:nth-child(1) {
        animation-delay: -0.32s;
    }

    .circle:nth-child(2) {
        animation-delay: -0.16s;
    }

    @@keyframes bounce {
        0%, 80%, 100% {
            transform: scale(0);
            opacity: 0.3;
        }
        40% {
            transform: scale(1);
            opacity: 1;
        }
    }

    /* Tabla y contenido */
    .card {
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        border-radius: 0.5rem;
        border: none;
        margin-bottom: 2rem;
    }

    .card-header {
