@page "/categories/{CategoryId:int}/subcategories"
@using FerrexWeb.Models
@using FerrexWeb.Services
@inject SubCategoryService SubCategoryService
@inject ProductService ProductService
@inject NavigationManager NavigationManager

<h1 class="text-center my-4">SubCategorías</h1>

@if (subCategories == null)
{
    <div class="d-flex justify-content-center align-items-center full-height">
        <div class="spinner-border" role="status" style="color: #F5C144;">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else
{
    <div class="container">
        <div class="row">
            @foreach (var subcat in subCategories)
            {
                // Ocultar subcategorías sin SubCategories2 y sin productos
                bool hasSub2 = subcat.SubCategories2 != null && subcat.SubCategories2.Any();
                bool hasProducts = firstProductMap.ContainsKey(subcat.id_subcategory);
                if (!hasSub2 && !hasProducts) continue;

                <div class="col-12 col-md-4 mb-4">
                    <div class="card category-card h-100 border-0">
                        <img src="@subcat.imageCat" class="card-img-top" alt="@subcat.subcategory" />
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@subcat.subcategory</h5>
                            <div class="mt-auto">
                                @if (hasSub2)
                                {
                                    <a href="@($"/subcategory2list/{subcat.id_subcategory}")"
                                       class="btn custom-btn">
                                        Ver Mas
                                    </a>
                                }
                                else
                                {
                                    var firstProd = firstProductMap[subcat.id_subcategory];
                                    <a href="@($"/productdetails/{firstProd.IdProducto}")"
                                       class="btn custom-btn">
                                        Ver Producto
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public int CategoryId { get; set; }

    private List<FerrexWeb.Models.SubCategory> subCategories;
    private Dictionary<int, Products> firstProductMap = new();

    protected override async Task OnInitializedAsync()
    {
        subCategories = await SubCategoryService.GetSubCategoriesByCategoryIdAsync(CategoryId);

        // Obtener subcategorías sin SubCategories2 que necesitan primer producto
        var subcatIdsWithoutSub2 = subCategories
            .Where(s => s.SubCategories2 == null || !s.SubCategories2.Any())
            .Select(s => s.id_subcategory)
            .ToList();

        if (subcatIdsWithoutSub2.Any())
        {
            firstProductMap = await ProductService.GetFirstProductBySubCategoryIdsAsync(subcatIdsWithoutSub2);
        }
    }
}

<style>
    .category-card {
        transition: transform 0.3s, box-shadow 0.3s;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    }

        .category-card:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }

    .card-img-top {
        width: 100%;
        height: 150px;
        object-fit: cover;
    }

    .card-body {
        padding: 0.75rem;
    }

    .card-title {
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .btn.custom-btn {
        background-color: #F5C144;
        border: none;
        color: #000;
        padding: 0.4rem 0.8rem;
        font-size: 0.8rem;
        transition: background-color 0.3s;
    }

        .btn.custom-btn:hover {
            background-color: #A7A9AC;
        }

    /* Responsivo */
    @@media (max-width: 576px) {
        .card-img-top

    {
        height: 100px;
    }

    .card-title {
        font-size: 0.8rem;
    }

    .btn.custom-btn {
        padding: 0.3rem 0.6rem;
        font-size: 0.7rem;
    }

    .card-body {
        padding: 0.5rem;
    }

    }
</style>