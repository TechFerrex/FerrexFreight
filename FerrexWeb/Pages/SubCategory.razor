@page "/categories/{CategoryId:int}/subcategories"
@using FerrexWeb.Models
@using FerrexWeb.Services
@inject SubCategoryService SubCategoryService
@inject ProductService ProductService
@inject NavigationManager NavigationManager

<h1 class="text-center my-4">SubCategorías</h1>

@if (subCategories == null)
{
    <div class="d-flex justify-content-center align-items-center full-height">
        <div class="spinner-border" role="status" style="color: #F5C144;">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else
{
    <div class="container">
        <div class="row">
            @foreach (var subcat in subCategories)
            {
                // Ocultar subcategorías sin SubCategories2 y sin productos
                bool hasSub2 = subcat.SubCategories2 != null && subcat.SubCategories2.Any();
                bool hasProducts = firstProductMap.ContainsKey(subcat.id_subcategory);
                if (!hasSub2 && !hasProducts) continue;

                <div class="col-12 col-md-4 mb-4">
                    <div class="card category-card h-100 border-0">
                        <img src="@GetSubcategoryImage(subcat)" class="card-img-top" alt="@subcat.subcategory" />
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@subcat.subcategory</h5>
                            <div class="mt-auto">
                                @if (hasSub2)
                                {
                                    <a href="@($"/subcategory2list/{subcat.id_subcategory}")"
                                       class="btn custom-btn">
                                        Ver Mas
                                    </a>
                                }
                                else
                                {
                                    var firstProd = firstProductMap[subcat.id_subcategory];
                                    <a href="@($"/productdetails/{firstProd.IdProducto}")"
                                       class="btn custom-btn">
                                        Ver Producto
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public int CategoryId { get; set; }

    private List<FerrexWeb.Models.SubCategory> subCategories;
    private Dictionary<int, Products> firstProductMap = new();

    protected override async Task OnInitializedAsync()
    {
        subCategories = await SubCategoryService.GetSubCategoriesByCategoryIdAsync(CategoryId);

        // Obtener primer producto de TODAS las subcategorías (para imagen fallback)
        var allSubcatIds = subCategories.Select(s => s.id_subcategory).ToList();
        if (allSubcatIds.Any())
        {
            firstProductMap = await ProductService.GetFirstProductBySubCategoryIdsAsync(allSubcatIds);
        }
    }

    private string GetSubcategoryImage(FerrexWeb.Models.SubCategory subcat)
    {
        // 1. Imagen propia de la subcategoría
        if (!string.IsNullOrEmpty(subcat.imageCat))
            return subcat.imageCat;

        // 2. Imagen del primer producto
        if (firstProductMap.TryGetValue(subcat.id_subcategory, out var prod))
            return prod.ImageUrl;

        // 3. Default
        return "images/product/default.png";
    }
}

<style>
    .category-card {
        transition: transform 0.3s, box-shadow 0.3s;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    }

        .category-card:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }

    .card-img-top {
        width: 100%;
        height: 150px;
        object-fit: cover;
    }

    .card-body {
        padding: 0.75rem;
    }

    .card-title {
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .btn.custom-btn {
        background-color: #F5C144;
        border: none;
        color: #000;
        padding: 0.4rem 0.8rem;
        font-size: 0.8rem;
        transition: background-color 0.3s;
    }

        .btn.custom-btn:hover {
            background-color: #A7A9AC;
        }

    /* Tablet */
    @@media (max-width: 768px) {
        .col-md-4 {
            flex: 0 0 50%;
            max-width: 50%;
        }

        .card-img-top {
            height: 130px;
        }

        .btn.custom-btn {
            min-height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
    }

    /* Movil */
    @@media (max-width: 480px) {
        .col-12.col-md-4 {
            flex: 0 0 100%;
            max-width: 100%;
        }

        .card-img-top {
            height: 120px;
        }

        .card-title {
            font-size: 0.85rem;
        }

        .btn.custom-btn {
            width: 100%;
            padding: 10px;
            font-size: 0.8rem;
        }

        .card-body {
            padding: 0.6rem;
        }

        .category-card:hover {
            transform: none;
        }
    }
</style>