@page "/"
@using FerrexWeb.Models
@using FerrexWeb.Services
@inject CategoryService CategoryService
@inject ProductService ProductService
@inject ApplicationDbContext DbContext

<!-- ========== HERO SECTION ========== -->
<section class="hero-section">
    <div class="hero-bg-overlay"></div>
    <div class="hero-particles">
        <div class="particle p1"></div>
        <div class="particle p2"></div>
        <div class="particle p3"></div>
        <div class="particle p4"></div>
        <div class="particle p5"></div>
    </div>
    <div class="hero-inner">
        <span class="hero-badge">Tu ferreteria y logistica en un solo lugar</span>
        <h1 class="hero-title">
            Todo lo que necesitas,
            <span class="hero-highlight">donde lo necesitas</span>
        </h1>
        <p class="hero-subtitle">
            Productos ferreteros, fletes a tu medida y servicios profesionales de reparacion y mantenimiento. FerrExpress conecta tu proyecto con soluciones reales.
        </p>
        <div class="hero-ctas">
            <NavLink href="/freight" class="hero-btn-primary">
                <i class="fas fa-truck-fast"></i> Cotiza tu Flete
            </NavLink>
            <NavLink href="/categories" class="hero-btn-secondary">
                <i class="fas fa-boxes-stacked"></i> Ver Productos
            </NavLink>
        </div>
        <div class="hero-trust-row">
            <div class="trust-item">
                <i class="fas fa-shield-alt"></i>
                <span>Envio seguro</span>
            </div>
            <div class="trust-divider"></div>
            <div class="trust-item">
                <i class="fas fa-map-marker-alt"></i>
                <span>Cobertura nacional</span>
            </div>
            <div class="trust-divider"></div>
            <div class="trust-item">
                <i class="fas fa-headset"></i>
                <span>Soporte directo</span>
            </div>
        </div>
    </div>
</section>

<!-- ========== SERVICIOS RAPIDOS (3 Pilares) ========== -->
<section class="pillars-section">
    <div class="container">
        <div class="pillars-grid">
            <!-- Pilar 1: Fletes -->
            <NavLink href="/freight" class="pillar-card pillar-freight">
                <div class="pillar-icon-wrap">
                    <div class="pillar-icon">
                        <i class="fas fa-truck-moving"></i>
                    </div>
                </div>
                <h3>Fletes y Logistica</h3>
                <p>Planifica tu ruta, agrega paradas y recibe una cotizacion al instante. Transporte confiable para materiales de construccion y mas.</p>
                <span class="pillar-link">
                    Cotizar ahora <i class="fas fa-arrow-right"></i>
                </span>
            </NavLink>

            <!-- Pilar 2: Productos -->
            <NavLink href="/categories" class="pillar-card pillar-products">
                <div class="pillar-icon-wrap">
                    <div class="pillar-icon">
                        <i class="fas fa-store"></i>
                    </div>
                </div>
                <h3>Productos Ferreteros</h3>
                <p>Acero, cemento, techos, PVC, electricos, tabla yeso y mas. Catalogo completo con precios y disponibilidad inmediata.</p>
                <span class="pillar-link">
                    Explorar catalogo <i class="fas fa-arrow-right"></i>
                </span>
            </NavLink>

            <!-- Pilar 3: Servicios -->
            <NavLink href="/service" class="pillar-card pillar-services">
                <div class="pillar-icon-wrap">
                    <div class="pillar-icon">
                        <i class="fas fa-tools"></i>
                    </div>
                </div>
                <h3>Servicios Profesionales</h3>
                <p>Fontaneria, electricidad, aire acondicionado e ingenieria. Manos expertas para tu hogar o negocio.</p>
                <span class="pillar-link">
                    Ver servicios <i class="fas fa-arrow-right"></i>
                </span>
            </NavLink>
        </div>
    </div>
</section>

<!-- ========== SECCION FLETES DESTACADA ========== -->
<section class="freight-showcase">
    <div class="container">
        <div class="freight-grid">
            <div class="freight-info">
                <span class="section-tag">Fletes Inteligentes</span>
                <h2>Tu carga, nuestra prioridad</h2>
                <p class="freight-desc">
                    Con nuestro sistema de cotizacion en linea, planifica rutas con multiples paradas,
                    calcula costos al instante y programa tu envio sin complicaciones.
                </p>
                <ul class="freight-features">
                    <li>
                        <div class="feature-icon"><i class="fas fa-route"></i></div>
                        <div>
                            <strong>Rutas personalizadas</strong>
                            <span>Agrega origen, destino y paradas intermedias</span>
                        </div>
                    </li>
                    <li>
                        <div class="feature-icon"><i class="fas fa-calculator"></i></div>
                        <div>
                            <strong>Cotizacion al instante</strong>
                            <span>Conoce el costo antes de confirmar</span>
                        </div>
                    </li>
                    <li>
                        <div class="feature-icon"><i class="fas fa-clock"></i></div>
                        <div>
                            <strong>Programacion flexible</strong>
                            <span>Elige la fecha y hora que mejor te convenga</span>
                        </div>
                    </li>
                    <li>
                        <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
                        <div>
                            <strong>Transporte seguro</strong>
                            <span>Tu mercancia protegida en todo momento</span>
                        </div>
                    </li>
                </ul>
                <NavLink href="/freight" class="freight-cta">
                    <i class="fas fa-truck-fast animated-truck"></i> Planifica tu Flete
                </NavLink>
            </div>
            <div class="freight-visual">
                <div class="freight-map-card">
                    <div class="map-header">
                        <div class="map-dot dot-green"></div>
                        <div class="map-dot dot-yellow"></div>
                        <div class="map-dot dot-red"></div>
                    </div>
                    <div class="map-body">
                        <div class="map-route-line"></div>
                        <div class="map-point mp-origin">
                            <i class="fas fa-circle"></i>
                            <span>Origen</span>
                        </div>
                        <div class="map-point mp-stop">
                            <i class="fas fa-map-pin"></i>
                            <span>Parada 1</span>
                        </div>
                        <div class="map-point mp-dest">
                            <i class="fas fa-flag-checkered"></i>
                            <span>Destino</span>
                        </div>
                        <div class="map-info-box">
                            <div class="map-info-row">
                                <i class="fas fa-road"></i>
                                <span>45.2 km</span>
                            </div>
                            <div class="map-info-row">
                                <i class="fas fa-clock"></i>
                                <span>~52 min</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== ESTADISTICAS / CONFIANZA ========== -->
<section class="stats-section">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-truck"></i></div>
                <div class="stat-number">500+</div>
                <div class="stat-label">Fletes realizados</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-box-open"></i></div>
                <div class="stat-number">2,000+</div>
                <div class="stat-label">Productos disponibles</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-users"></i></div>
                <div class="stat-number">300+</div>
                <div class="stat-label">Clientes satisfechos</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-star"></i></div>
                <div class="stat-number">4.8</div>
                <div class="stat-label">Calificacion promedio</div>
            </div>
        </div>
    </div>
</section>

<!-- ========== PRODUCTOS DESTACADOS ========== -->
<section class="products-section">
    <div class="container">
        <div class="section-header-center">
            <span class="section-tag">Catalogo</span>
            <h2>Productos para cada proyecto</h2>
            <p>Materiales de construccion, ferreteria y mas. Todo en un solo lugar.</p>
        </div>
        <div class="products-grid">
            <NavLink href="/categories" class="product-cat-card pcc-steel">
                <div class="pcc-icon"><i class="fas fa-industry"></i></div>
                <h4>Acero y Hierro</h4>
                <span>Varillas, tubos, angulos, platinas</span>
            </NavLink>
            <NavLink href="/categories" class="product-cat-card pcc-cement">
                <div class="pcc-icon"><i class="fas fa-cubes"></i></div>
                <h4>Cemento y Agregados</h4>
                <span>Bloques, pegamentos, morteros</span>
            </NavLink>
            <NavLink href="/categories" class="product-cat-card pcc-roof">
                <div class="pcc-icon"><i class="fas fa-home"></i></div>
                <h4>Techos y Laminas</h4>
                <span>Aluminio, traslucidas, canaletas</span>
            </NavLink>
            <NavLink href="/categories" class="product-cat-card pcc-pvc">
                <div class="pcc-icon"><i class="fas fa-faucet"></i></div>
                <h4>PVC y Fontaneria</h4>
                <span>Tubos, codos, pegamentos</span>
            </NavLink>
            <NavLink href="/categories" class="product-cat-card pcc-elec">
                <div class="pcc-icon"><i class="fas fa-bolt"></i></div>
                <h4>Electricos</h4>
                <span>Cables, poliductos, conduit</span>
            </NavLink>
            <NavLink href="/categories" class="product-cat-card pcc-dry">
                <div class="pcc-icon"><i class="fas fa-layer-group"></i></div>
                <h4>Tabla Yeso</h4>
                <span>Laminas, perfiles, accesorios</span>
            </NavLink>
        </div>
        <div class="text-center" style="margin-top: 2.5rem;">
            <NavLink href="/categories" class="btn-see-all">
                Ver todo el catalogo <i class="fas fa-arrow-right"></i>
            </NavLink>
        </div>
    </div>
</section>

<!-- ========== SERVICIOS PROFESIONALES ========== -->
<section class="services-home-section">
    <div class="container">
        <div class="section-header-center">
            <span class="section-tag-dark">Nuevo</span>
            <h2>Servicios de Reparacion y Mantenimiento</h2>
            <p>Soluciones profesionales para tu hogar o negocio</p>
        </div>
        <div class="services-grid">
            <div class="srv-card srv-featured">
                <div class="srv-badge">Destacado</div>
                <div class="srv-icon srv-icon-eng">
                    <i class="fas fa-hard-hat"></i>
                </div>
                <h4>Ingenieria</h4>
                <p>Revision de proyectos, presupuestos de materiales y asesoria tecnica</p>
                <a href="https://wa.me/50432024761?text=Hola%2C%20me%20interesa%20el%20servicio%20de%20ingeniería"
                   target="_blank" class="srv-contact">
                    <i class="fab fa-whatsapp"></i> Consultar
                </a>
            </div>
            <div class="srv-card">
                <div class="srv-icon">
                    <i class="fas fa-faucet"></i>
                </div>
                <h4>Fontaneria</h4>
                <p>Fugas, tuberias, grifos, calentadores y drenajes</p>
                <a href="https://wa.me/50432024761?text=Hola%2C%20necesito%20un%20servicio%20de%20fontanería"
                   target="_blank" class="srv-contact">
                    <i class="fab fa-whatsapp"></i> Consultar
                </a>
            </div>
            <div class="srv-card">
                <div class="srv-icon">
                    <i class="fas fa-bolt"></i>
                </div>
                <h4>Electricidad</h4>
                <p>Instalaciones, cableado, paneles e iluminacion</p>
                <a href="https://wa.me/50432024761?text=Hola%2C%20necesito%20un%20servicio%20de%20electricidad"
                   target="_blank" class="srv-contact">
                    <i class="fab fa-whatsapp"></i> Consultar
                </a>
            </div>
            <div class="srv-card">
                <div class="srv-icon">
                    <i class="fas fa-snowflake"></i>
                </div>
                <h4>Aire Acondicionado</h4>
                <p>Instalacion, limpieza, mantenimiento y diagnostico</p>
                <a href="https://wa.me/50432024761?text=Hola%2C%20necesito%20un%20servicio%20de%20aire%20acondicionado"
                   target="_blank" class="srv-contact">
                    <i class="fab fa-whatsapp"></i> Consultar
                </a>
            </div>
        </div>
        <div class="text-center" style="margin-top: 2rem;">
            <NavLink href="/service" class="btn-services-all">
                Ver todos los servicios <i class="fas fa-arrow-right"></i>
            </NavLink>
        </div>
    </div>
</section>

<!-- ========== POR QUE ELEGIRNOS ========== -->
