<!-- MainLayout.razor -->
@using Microsoft.AspNetCore.Components
@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@using FerrexWeb.Pages
@using FerrexWeb.Layout


<PageTitle>FerrExpress</PageTitle>

<!-- Contenedor general que llena toda la altura de la ventana -->
<div class="page d-flex flex-column min-vh-100">

    <!-- Barra de navegación fija -->
    <div class="sticky-nav">
        <NavMenu/>
    </div>

    <!-- Contenido que puede crecer; empuja el footer hacia abajo -->
    <main class="flex-fill">
        <article class="content px-1">
            @Body
        </article>
    </main>

    <!-- Un solo footer para toda la app -->
    <Footer />

</div>

<CookieConsent />
<a href="https://wa.me/50432024761?text=Hola%20FerrExpress" class="whatsapp" target="_blank">
    <i class="fab fa-whatsapp"></i>
</a>
<NotificationComponent />

<style>
    .sticky-nav {
        position: sticky;
        top: 0;
        width: 100%;
        z-index: 1000;
        background: #fff;
    }

    @@keyframes pulsate {
        0% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.1);
            opacity: 0.7;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    .whatsapp {
        position: fixed;
        display: flex;
        justify-content: center;
        align-items: center;
        width: 60px;
        height: 60px;
        bottom: 100px;
        right: 40px;
        background-color: #25d366;
        color: #FFF;
        border-radius: 50%;
        font-size: 30px;
        z-index: 9999;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        animation: pulsate 2s infinite;     
        text-decoration: none;
    }

    .whatsapp-icon {
        margin-top: 13px;
    }
    @@media (max-width: 768px) {
        .whatsapp

    {
        bottom: 200px; /* Ajusta este valor según convenga */
    }

    }
</style>
