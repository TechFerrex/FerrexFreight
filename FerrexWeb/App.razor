@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Routing



<ErrorBoundary @ref="errorBoundary">
    <ChildContent>
<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <NoAuthorized />
                </NotAuthorized>
                <Authorizing>
                    <div style="display:none;"></div>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <Error404 />
        </NotFound>
    </Router>
</CascadingAuthenticationState>
    </ChildContent>
    <ErrorContent Context="ex">
        <div class="alert alert-danger m-4">
            <h4>Error en la aplicacion</h4>
            <p><strong>Tipo:</strong> @ex.GetType().Name</p>
            <p><strong>Mensaje:</strong> @ex.Message</p>
            @if (ex.InnerException != null)
            {
                <p><strong>Detalle:</strong> @ex.InnerException.Message</p>
            }
            <hr />
            <a href="/" class="btn btn-primary" @onclick="RecoverError">Volver al inicio</a>
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    private ErrorBoundary? errorBoundary;

    private void RecoverError()
    {
        errorBoundary?.Recover();
    }
}