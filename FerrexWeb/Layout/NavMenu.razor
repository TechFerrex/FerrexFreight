@using FerrexWeb.Pages
@using FerrexWeb.Services
@implements IDisposable
@inject ShoppingCartService CartService
@inject AuthenticationStateProvider AuthenticationStateProvider

<div class="navbar-brand logo-container">
    <img src="images/logopage.webp" alt="Logo" class="logo-img">
</div>
<!-- Barra de navegación superior -->
<nav class="navbar navbar-expand-lg navbar-light bg-white top-navbar">
    <div class="container-fluid">
        <!-- Buscador -->
        <div class="search-container">
            <Seeker />
        </div>

        <!-- Íconos Centrales para Escritorio -->
        <div class="d-none d-lg-flex central-icons">
            <ul class="navbar-nav">
                <!-- Inicio -->
                <li class="nav-item mx-2">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <i class="fas fa-home" title="Inicio"></i>
                    </NavLink>
                </li>
                <li class="nav-item mx-2">
                    <NavLink class="nav-link" href="freight">
                        <i class="fas fa-truck-fast" title="Fletes"></i>
                        
                    </NavLink>
                </li>




@*                 <!-- Servicios -->
                <li class="nav-item mx-2">
                    <NavLink class="nav-link nav-service-link" href="service">
                        <img class="service-icon" src="iconos/iconoservicio.svg" alt="Servicio" title="Servicio" style="width: 26px; height: 26px;">
                    </NavLink>
                </li> *@
                <!-- Mis Cotizaciones -->
                <li class="nav-item mx-2">
                    <NavLink class="nav-link" href="freightquotations">
                        <i class="fas fa-file-invoice-dollar" title="Tus Cotizaciones"></i>
                    </NavLink>
                </li>
                <!-- Categoría -->
                <li class="nav-item mx-2">
                    <NavLink class="nav-link" href="categories">
                        <i class="fas fa-th-list" title="Categorías"></i>
                    </NavLink>
                </li>
                <!-- Cotizaciones de Productos -->
                <li class="nav-item mx-2">
                    <NavLink class="nav-link" href="quotations">
                        <i class="fas fa-clipboard-list" title="Cotizaciones Productos"></i>
                    </NavLink>
                </li>
                <!-- Contáctanos -->
                <li class="nav-item mx-2">
                    <NavLink class="nav-link" href="contact">
                        <i class="fas fa-address-book" title="Contacto"></i>
                    </NavLink>
                </li>
                <AuthorizeView Roles="SuperAdmin">
                    <li class="nav-item mx-2">
                        <NavLink class="nav-link highlighted-icon" href="/admin" Match="NavLinkMatch.All">
                            <i class="fas fa-user-secret" title="Administrador"></i>
                        </NavLink>
                    </li>
                </AuthorizeView>
            </ul>
        </div>

        <!-- Carrito e Ícono de Usuario -->
        <div class="d-flex align-items-center right-icons">
            <ul class="navbar-nav flex-row">
                <!-- Icono del Carrito -->
                <li class="nav-item position-relative">
                    <a class="nav-link" href="cart">
                        <Icon Name="IconName.Cart2" title="Carrito" />
                        @if (CartItemCount > 0)
                        {
                            <span class="badge badge-danger position-absolute top-0 start-100 translate-middle">
                                @CartItemCount
                                <span class="visually-hidden">elementos en el carrito</span>
                            </span>
                        }
                    </a>
                </li>
                <!-- Icono del Usuario -->
                <li class="nav-item">
                    <AuthorizeView>
                        <Authorized>
                            <a class="nav-link" href="profile">
                                <Icon Name="IconName.Person" title="Usuario" />
                            </a>
                        </Authorized>
                        <NotAuthorized>
                            <a class="nav-link" href="userinfo">
                                <Icon Name="IconName.Person" title="Usuario" />
                            </a>
                        </NotAuthorized>
                    </AuthorizeView>
                </li>
            </ul>
        </div>
    </div>
</nav>

<!-- Barra de navegación inferior solo para móviles -->
<nav class="bottom-navbar d-lg-none">
    <div class="bottom-nav-items">
        <!-- Inicio -->
        <NavLink class="bottom-nav-link" href="" Match="NavLinkMatch.All">
            <i class="fas fa-home"></i>
            <span>Inicio</span>
        </NavLink>
        <!-- Categorías -->
        <NavLink class="bottom-nav-link" href="categories">
            <i class="fas fa-th-list"></i>
            <span>Productos</span>
        </NavLink>
        <!-- Fletes -->
        <NavLink class="bottom-nav-link" href="freight">
            <i class="fas fa-truck-fast"></i>
            <span>Fletes</span>
        </NavLink>
        <!-- Carrito -->
        <NavLink class="bottom-nav-link" href="cart">
            <div class="bottom-nav-icon-wrapper">
                <i class="fas fa-shopping-cart"></i>
                @if (CartItemCount > 0)
                {
                    <span class="bottom-nav-badge">@CartItemCount</span>
                }
            </div>
            <span>Carrito</span>
        </NavLink>
        <!-- Más -->
        <button class="bottom-nav-link" @onclick="ToggleMoreMenu">
            <i class="fas fa-ellipsis-h"></i>
            <span>Más</span>
        </button>
    </div>

    <!-- Panel expandible de "Más" -->
    @if (showMoreMenu)
    {
        <div class="more-menu-overlay" @onclick="ToggleMoreMenu"></div>
        <div class="more-menu">
            <div class="more-menu-header">
                <span>Más opciones</span>
                <button class="more-menu-close" @onclick="ToggleMoreMenu">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <NavLink class="more-menu-item" href="freightquotations" @onclick="ToggleMoreMenu">
                <i class="fas fa-file-invoice-dollar"></i>
                <span>Mis Cotizaciones de Fletes</span>
            </NavLink>
            <NavLink class="more-menu-item" href="quotations" @onclick="ToggleMoreMenu">
                <i class="fas fa-clipboard-list"></i>
                <span>Cotizaciones de Productos</span>
            </NavLink>
            <NavLink class="more-menu-item" href="contact" @onclick="ToggleMoreMenu">
                <i class="fas fa-address-book"></i>
                <span>Contacto</span>
            </NavLink>
            <AuthorizeView>
                <Authorized>
                    <NavLink class="more-menu-item" href="profile" @onclick="ToggleMoreMenu">
                        <i class="fas fa-user"></i>
                        <span>Mi Perfil</span>
                    </NavLink>
                </Authorized>
                <NotAuthorized>
                    <NavLink class="more-menu-item" href="userinfo" @onclick="ToggleMoreMenu">
                        <i class="fas fa-sign-in-alt"></i>
                        <span>Iniciar Sesión</span>
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>
            <AuthorizeView Roles="SuperAdmin">
                <NavLink class="more-menu-item more-menu-admin" href="/admin" Match="NavLinkMatch.All" @onclick="ToggleMoreMenu">
                    <i class="fas fa-user-secret"></i>
                    <span>Administrador</span>
                </NavLink>
            </AuthorizeView>
        </div>
    }
</nav>

@code {
    private bool navMenuVisible;
    private bool isSuperAdmin;
    private int CartItemCount = 0;
    private bool showMoreMenu = false;

    private void ToggleMoreMenu()
    {
        showMoreMenu = !showMoreMenu;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CartService.EnsureInitializedAsync();
            UpdateCartCount();
            CartService.OnChange += UpdateCartCount;
            StateHasChanged();
        }
    }

    private void UpdateCartCount()
    {
        CartItemCount = CartService.Items.Count;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        CartService.OnChange -= UpdateCartCount;
    }

    [Inject] NavigationManager NavManager { get; set; }
}


<style>
    /* Aplica el color por defecto */
 
    .service-icon {
    filter: brightness(0) saturate(100%) invert(46%) sepia(5%) saturate(294%) hue-rotate(155deg) brightness(96%) contrast(92%);
    transition: filter 0.3s ease-in-out;
    }

    /* Cambia el color cuando se hace hover sobre el enlace */
    .nav-service-link:hover .service-icon {
        filter: brightness(0) saturate(100%) invert(28%) sepia(10%) saturate(153%) hue-rotate(22deg) brightness(95%) contrast(84%);
    }

    /* Cambia el color cuando el enlace está seleccionado */
    .nav-service-link.active .service-icon {
filter: brightness(0) saturate(100%) invert(6%) sepia(1%) saturate(4221%) hue-rotate(202deg) brightness(110%) contrast(96%);
    }




    .badge-danger {
        background-color: #dc3545;
        color: white;
        font-size: 0.75rem;
        padding: 0.5em 0.6em;
        border-radius: 50%;
    }

    .position-relative .badge {
        transform: translate(-50%, -50%);
    }
.navbar .nav-link {
    color: #000;
    transition: color 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    padding: 0.5rem;
}

    @@media (max-width: 991.98px) {
        .navbar .nav-link {
            font-size: 1.3rem;
            padding: 0.4rem;
        }

        .top-navbar {
            padding: 4px 0;
