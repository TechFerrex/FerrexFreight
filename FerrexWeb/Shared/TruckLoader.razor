@* Components/TruckLoader.razor *@
<div class="TruckLoader">
    <div class="TruckLoader-cab"></div>
    <div class="TruckLoader-smoke"></div>
    <div class="TruckLoader-label">FERREXPRESS</div>
</div>

 <style>
     .TruckLoader {
    position: relative;
    width: 150px;
    height: 40px;
    background: #F5C144;
    animation: put-put 2s infinite ease-in-out;
    background-size: 100% auto;
    border-radius: 4px;
        top: -20px; /* ajusta este valor hasta que queden perfectamente visibles */
        z-index: 10;
        -webkit-box-reflect: below 15px -webkit-gradient(linear, left top, left bottom, from(transparent), color-stop(0.1, transparent), to(rgba(255,255,255,0.1)));
}
    /* Etiqueta */
    .TruckLoader .TruckLoader-label {
        font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: #000;
        font-size: 14px;
        font-weight: bold;
        white-space: nowrap;
    }

    /*-webkit-box-reflect:
    below 15px
    -webkit-gradient(linear, left top, left bottom, from(transparent), color-stop(0.1, transparent), to(rgba(255, 255, 255, 0.1)));
*/

    .TruckLoader::before,
    .TruckLoader::after {
        content: '';
        display: block;
        border-radius: 50%;
        width: 16px;
        height: 16px;
        border: 2px solid #fff;
        background: #333;
        position: absolute;
        bottom: -10px;
    }

    .TruckLoader::before {
        left: 6px;
    }

    .TruckLoader::after {
        right: 6px;
    }


.TruckLoader-cab {
    position: absolute;
    left: -35px;
    bottom: 0;
    width: 33px;
    height: 25px;
    background: #333;
    border-radius: 40% 0 4px 4px;
    -webkit-box-reflect: below 15px -webkit-gradient(linear, left top, left bottom, from(transparent), color-stop(0.1, transparent), to(rgba(255,255,255,0.1)));
}

    .TruckLoader-cab::before {
        content: '';
        position: absolute;
        width: 20px;
        height: 15px;
        top: -15px;
        right: 0;
        background: #333;
        border-radius: 100% 0 0 0;
    }

    .TruckLoader-cab::after {
        content: '';
        position: absolute;
        width: 16px;
        height: 16px;
        left: 5px;
        bottom: -10px;
        border: 2px solid #fff;
        background: #333;
        border-radius: 50%;
    }

.TruckLoader-smoke,
.TruckLoader-smoke::before,
.TruckLoader-smoke::after {
    position: absolute;
    content: '';
    display: block;
    width: 10px;
    height: 10px;
    right: -1px;
    bottom: -5px;
    border-radius: 50%;
    background: #333;
}

.TruckLoader-smoke {
    animation: smoke-1 2s infinite;
}

    .TruckLoader-smoke::before {
        animation: smoke-2 3s infinite;
    }

    .TruckLoader-smoke::after {
        animation: smoke-3 4s infinite;
    }

